@{
    var current = (ViewBag.CurrentPage?.ToString() ?? "home").ToLowerInvariant();
    var role = (ViewBag.Role?.ToString() ?? "Student").Trim();
    var isTeacher = role.Equals("Teacher", StringComparison.OrdinalIgnoreCase);
    var isProfessor = role.Equals("Professor", StringComparison.OrdinalIgnoreCase);
    var dashboardUrl = (isTeacher || isProfessor)
        ? Url.Content("~/professordb/ProfessorDb")
        : Url.Content("~/studentdb/StudentDb");
    string Active(string key) => current == key ? "active" : "";
}
<nav class="slsp-bottom-nav" aria-label="Mobile navigation" role="navigation">
    <a class="slsp-bottom-nav-item @Active("home")" href="@dashboardUrl">
        <i class="fa-solid fa-house"></i>
        <span>Dashboard</span>
    </a>
    @if (isTeacher || isProfessor)
    {
        <a class="slsp-bottom-nav-item @Active("schedule")" href="@Url.Content("~/teacherdb/TeacherDb/Schedule")">
            <i class="fa-solid fa-calendar-days"></i>
            <span>Schedule</span>
        </a>
        <a class="slsp-bottom-nav-item @Active("settings")" href="@Url.Content("~/teacherdb/TeacherDb/Settings")">
            <i class="fa-solid fa-gear"></i>
            <span>Settings</span>
        </a>
    }
    @if (!isTeacher && !isProfessor)
    {
        <a class="slsp-bottom-nav-item @Active("library")" href="@Url.Action("Search","Library")">
            <i class="fa-solid fa-book"></i>
            <span>Library</span>
        </a>
        <a class="slsp-bottom-nav-item @Active("todo")" href="@Url.Content("~/StudentTodo")">
            <i class="fa-solid fa-list-check"></i>
            <span>To-Do</span>
        </a>
    }
</nav>
