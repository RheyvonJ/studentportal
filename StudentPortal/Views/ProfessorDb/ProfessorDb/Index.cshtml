@model StudentPortal.Models.ProfessorDb.ProfessorDashboardViewModel
@{
    Layout = "_StudentLayout";
    ViewData["Title"] = "Dashboard";
    ViewBag.CurrentPage = "home";
    ViewBag.Role = "Professor";
    ViewBag.AdminName = Model.ProfessorName;
    ViewBag.AdminInitials = Model.ProfessorInitials;
    var toastMessage = TempData["ToastMessage"] as string;
}

@section Styles {
    <link rel="stylesheet" href="~/css/StudentDb/StudentDb.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Shared/BottomBar.css" asp-append-version="true" />
    <style>
        .modal {
            width: 260px;
            padding: 16px;
            background: #f3f6fb;
            color: #0b213a;
            box-shadow: 0 10px 26px rgba(24, 43, 92, 0.18);
            border-radius: 10px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            bottom: 90px;
            right: 100px;
        }

        .modal h3 {
            margin: 0;
            font-size: 15px;
            color: var(--accent);
            font-weight: 700;
        }

        .modal input[type="text"] {
            width: 210px;
            height: 34px;
            padding: 6px 10px;
            border-radius: 8px;
            border: 1px solid rgba(16, 24, 40, 0.08);
            background: #fff;
            color: #0b213a;
            font-size: 13px;
            margin-bottom: 5px;
        }

        .modal input[type="text"]:disabled {
            background: #eef2f7;
            color: #334155;
            cursor: not-allowed;
        }

        .custom-select {
            position: relative;
            width: 230px;
            font-size: 13px;
            color: #0b213a;
            user-select: none;
            margin-bottom: 5px;
        }

        .custom-select .selected {
            background: #fff;
            border: 1px solid rgba(16, 24, 40, 0.08);
            border-radius: 8px;
            padding: 6px 10px;
            cursor: pointer;
            position: relative;
        }

        .custom-select .selected::after {
            content: '';
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%) rotate(45deg);
            width: 6px;
            height: 6px;
            border-right: 2px solid var(--accent);
            border-bottom: 2px solid var(--accent);
            transition: transform 0.2s ease;
        }

        .custom-select.open .selected::after {
            transform: translateY(-50%) rotate(-135deg);
        }

        .custom-select .options {
            position: absolute;
            top: 110%;
            left: 0;
            width: 100%;
            background: #fff;
            border: 1px solid rgba(16, 24, 40, 0.08);
            border-radius: 8px;
            box-shadow: 0 6px 20px rgba(24, 43, 92, 0.15);
            max-height: 220px;
            overflow: auto;
            opacity: 0;
            visibility: hidden;
            transform: translateY(-5px);
            transition: all 0.2s ease;
            z-index: 10002;
        }

        .custom-select.open .options {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .custom-select .options div {
            padding: 8px 10px;
            cursor: pointer;
            transition: background 0.2s ease;
        }

        .custom-select .options div:hover {
            background: #f3f6fb;
            color: var(--accent);
        }

        .modal button {
            width: 210px;
            height: 36px;
            border-radius: 8px;
            background-color: var(--accent);
            color: #fff;
            border: none;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.2s ease, transform 0.2s ease;
        }

        .modal button:hover {
            background: #12283e;
            transform: translateY(-2px);
        }

        .create-class-button {
            position: fixed;
            right: 24px;
            bottom: calc(28px + env(safe-area-inset-bottom, 0));
            width: 56px;
            height: 56px;
            border-radius: 50%;
            border: 1px solid rgba(0, 31, 63, 0.12);
            background: #fff;
            color: #0b4a89;
            box-shadow: 0 10px 28px rgba(0, 31, 63, 0.2);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            z-index: 10001;
            cursor: pointer;
        }

        .create-class-button:hover {
            transform: translateY(-1px);
            box-shadow: 0 14px 34px rgba(0, 31, 63, 0.24);
        }

        .class-card {
            position: relative;
        }

        .prof-class-actions {
            position: absolute;
            top: 12px;
            right: 12px;
            z-index: 2;
            display: flex;
            gap: 6px;
            opacity: 0;
            transition: opacity 0.2s ease;
        }

        .class-card:hover .prof-class-actions {
            opacity: 1;
        }

        .prof-class-actions .delete-class-btn {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            border: none;
            background: rgba(255, 255, 255, 0.95);
            box-shadow: 0 2px 8px rgba(0, 31, 63, 0.12);
            color: #475569;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .prof-class-actions .delete-class-btn:hover {
            color: #dc2626;
            background: #fff;
        }

        .classes-container .class-card .class-card-status.status-archived {
            background: rgba(100, 116, 139, 0.12);
            color: #475569;
            border: 1px solid rgba(100, 116, 139, 0.2);
        }

        @@media (max-width: 768px) {
            .modal {
                width: calc(100% - 24px);
                max-width: 340px;
                left: 50%;
                right: auto;
                transform: translateX(-50%);
                box-sizing: border-box;
            }

            .modal button,
            .modal input[type="text"],
            .custom-select {
                width: 100%;
                max-width: 100%;
                box-sizing: border-box;
            }
        }
    </style>
}

<main class="dashboard slsp-student-dashboard professor-db-dashboard" id="dashboard">
    <section class="slsp-mobile-dashboard-greet" aria-label="Welcome">
        <div class="slsp-mobile-greet-avatar" aria-hidden="true">@Model.ProfessorInitials</div>
        <div class="slsp-mobile-greet-text">
            <div class="slsp-mobile-greet-line">Hi, <span class="slsp-mobile-greet-name">@Model.ProfessorName</span></div>
            <div class="slsp-mobile-greet-sub">Welcome back</div>
        </div>
    </section>
    <section class="dashboard-top">
        <div class="courses-scroll classes-container" id="coursesScroll">
            @if (Model.Classes != null && Model.Classes.Any())
            {
                foreach (var cls in Model.Classes)
                {
                    <article class="class-card active" data-href="@Url.Action("Index", "AdminClass", new { id = cls.ClassCode })" data-class-code="@cls.ClassCode" data-subject-name="@cls.SubjectName" data-section-label="@(string.IsNullOrWhiteSpace(cls.SectionLabel) ? cls.Section : cls.SectionLabel)" role="button" tabindex="0">
                        <span class="class-card-status @(cls.IsArchived ? "status-archived" : "status-active")">@(cls.IsArchived ? "Archived" : "Active")</span>
                        <div class="prof-class-actions" aria-label="Class actions">
                            <button type="button" class="delete-class-btn" data-class-id="@cls.Id" data-class-code="@cls.ClassCode" title="Archive / Delete class" aria-label="Archive or delete this class">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </div>

                        <div class="class-card-top">
                            <div class="class-title-wrap">
                                <i class="fa-solid fa-book-open class-title-icon" aria-hidden="true"></i>
                                <div>
                                    <h3 class="class-title">@cls.SubjectName</h3>
                                    <div class="class-subtitle">@(!string.IsNullOrWhiteSpace(cls.SubjectCode) ? cls.SubjectCode : "—")</div>
                                </div>
                            </div>
                        </div>
                        <div class="class-card-divider" aria-hidden="true"></div>
                        <div class="class-card-bottom">
                            <div class="detail-grid">
                                <div class="detail-row">
                                    <i class="fa-solid fa-users" aria-hidden="true"></i>
                                    <span class="detail-label">Section</span>
                                    <span class="detail-value">@(string.IsNullOrWhiteSpace(cls.SectionLabel) ? cls.Section : cls.SectionLabel)</span>
                                </div>
                                <div class="detail-row">
                                    <i class="fa-solid fa-clock" aria-hidden="true"></i>
                                    <span class="detail-label">Schedule</span>
                                    <span class="detail-value">
                                        @if (string.IsNullOrWhiteSpace(cls.RoomDisplay) && string.IsNullOrWhiteSpace(cls.ScheduleTimeDisplay))
                                        {
                                            <text>—</text>
                                        }
                                        else
                                        {
                                            <text>@(string.IsNullOrWhiteSpace(cls.ScheduleTimeDisplay) ? "" : cls.ScheduleTimeDisplay)</text>
                                            @if (!string.IsNullOrWhiteSpace(cls.RoomDisplay))
                                            {
                                                <text>@(string.IsNullOrWhiteSpace(cls.ScheduleTimeDisplay) ? "" : " • ")@cls.RoomDisplay</text>
                                            }
                                        }
                                    </span>
                                </div>
                                <div class="detail-row">
                                    <i class="fa-solid fa-hashtag" aria-hidden="true"></i>
                                    <span class="detail-label">Class Code</span>
                                    <span class="detail-value detail-code">@cls.ClassCode</span>
                                </div>
                            </div>
                        </div>
                        <div class="class-card-footer">
                            <div class="class-card-professor">
                                <span class="class-card-professor-name">@Model.ProfessorName</span>
                            </div>
                        </div>
                    </article>
                }
            }
            else
            {
                <p>No classes found.</p>
            }
        </div>
    </section>

    <section class="dashboard-content"></section>
</main>

<button class="create-class-button" id="createBtn" type="button" title="Create class" aria-haspopup="dialog" aria-controls="createModal">
    <i class="fa-solid fa-pen-to-square"></i>
</button>

<div class="modal-backdrop" id="modalBackdrop" role="presentation" aria-hidden="true">
    <div class="modal" id="createModal" role="dialog" aria-modal="true" aria-labelledby="createTitle">
        <h3 id="createTitle">Create a Class</h3>

        <form id="createForm" method="post" asp-controller="ProfessorDb" asp-action="CreateClass">
            @Html.AntiForgeryToken()
            <input type="hidden" name="allowDuplicate" id="allowDuplicate" value="false" />
            <div class="custom-select" id="schoolYearSelect" data-value="">
                <div class="selected">Select School Year</div>
                <div class="options"></div>
            </div>
            <div class="custom-select" id="profSubjectSelect" data-value="">
                <div class="selected">Select School Year first</div>
                <div class="options"></div>
            </div>
            <input type="hidden" id="profSubjectValue" />
            <input type="hidden" id="section" name="section" />
            <input type="hidden" id="subjectName" name="subjectName" />
            <input type="hidden" id="subjectCode" name="subjectCode" />
            <input type="hidden" id="schoolYear" name="schoolYear" />
            <input type="hidden" id="scheduleId" name="scheduleId" />
            <input type="hidden" id="sectionId" name="sectionId" />
            <input type="text" id="sectionText" placeholder="Section" disabled />
            <input type="text" id="subjectNameText" placeholder="Subject Name" disabled />
            <input type="text" id="subjectCodeText" placeholder="Subject Code" disabled />
            <button id="createClass" type="submit">CREATE CLASS</button>
        </form>
    </div>
</div>

<div id="toast" class="toast">@toastMessage</div>

<div id="deleteClassConfirmBackdrop" class="slsp-confirm-backdrop" hidden aria-hidden="true"></div>
<div id="deleteClassConfirmModal" class="slsp-confirm-modal" role="dialog" aria-modal="true" aria-labelledby="deleteClassConfirmTitle" hidden>
    <div class="slsp-confirm-card">
        <div class="slsp-confirm-header">
            <div class="slsp-confirm-icon" aria-hidden="true"><i class="fa-solid fa-trash"></i></div>
            <h2 id="deleteClassConfirmTitle" class="slsp-confirm-title">Delete class</h2>
            <p id="deleteClassText" class="slsp-confirm-desc"></p>
        </div>
        <div class="slsp-confirm-actions">
            <button type="button" id="cancelDeleteClass" class="slsp-confirm-btn slsp-confirm-cancel">Cancel</button>
            <button type="button" id="confirmDeleteClass" class="slsp-confirm-btn slsp-confirm-primary">Delete</button>
        </div>
    </div>
</div>

<div id="createClassConfirmBackdrop" class="slsp-confirm-backdrop" hidden aria-hidden="true"></div>
<div id="createClassConfirmModal" class="slsp-confirm-modal" role="dialog" aria-modal="true" aria-labelledby="createClassConfirmTitle" hidden>
    <div class="slsp-confirm-card">
        <div class="slsp-confirm-header">
            <div class="slsp-confirm-icon" aria-hidden="true"><i class="fa-solid fa-chalkboard-user"></i></div>
            <h2 id="createClassConfirmTitle" class="slsp-confirm-title">Create class</h2>
            <p id="createClassConfirmDesc" class="slsp-confirm-desc"></p>
        </div>
        <div class="slsp-confirm-actions">
            <button type="button" id="createClassConfirmCancel" class="slsp-confirm-btn slsp-confirm-cancel">Cancel</button>
            <button type="button" id="createClassConfirmOk" class="slsp-confirm-btn slsp-confirm-primary">Create class</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>(function(){try{if(document&&document.body){document.body.dataset.role='Professor';}else{document.addEventListener('DOMContentLoaded',function(){document.body.dataset.role='Professor';});}}catch(e){}})();</script>
    <script src="~/js/AdminDb/AdminDb.js" asp-append-version="true"></script>
}


