@model StudentPortal.Models.AdminMaterial.AdminMaterialViewModel
@{
    Layout = null;
    ViewData["Title"] = $"LMS — Material Page (Admin)";
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/admindb/adminmaterial.css" asp-append-version="true" />
</head>
<body data-class-code="@Model.ClassCode">
    <div class="page">
        <main class="class-container">
            <!-- LEFT SECTION -->
            <section class="class-info">
                <div class="class-info-top">
                    <div class="class-banner" style="background:url('c:/Users/Vaughn/source/repos/StudentPortal/.vs/StudentPortal/FileContentIndex/30dbce06-8735-4efb-b780-868848a98c3d.vsidx') center/cover no-repeat;">
                    <div class="profile-initials" aria-hidden="true">@Model.InstructorInitials</div>
                        <div class="teacher-details">
                        <div class="teacher-name">@Model.InstructorName</div>
                        <div class="teacher-meta">
                            @Model.TeacherRole
                            @if (!string.IsNullOrWhiteSpace(Model.TeacherDepartment))
                            {
                                <text> | @Model.TeacherDepartment</text>
                            }
                        </div>
                        <div class="room-location">
                            @Model.RoomName
                            @if (!string.IsNullOrWhiteSpace(Model.FloorDisplay))
                            {
                                <text> • @Model.FloorDisplay</text>
                            }
                        </div>
                        </div>
                    </div>
                </div>

                <div class="class-info-middle-top">
                    <h2 class="subject-name">@Model.SubjectName</h2>
                    <p class="subject-code">Subject Code: <span class="code-value">@Model.SubjectCode</span></p>
                    <p class="class-code">Class Code: <span class="code-value">@Model.ClassCode</span></p>
                </div>

                <div class="class-info-middle">
                    <div class="recent-uploads">
                        <h3>Recent Materials</h3>
                        <ul>
                            @foreach (var u in Model.RecentMaterials)
                            {
                                <li><i class="fa-solid fa-book-open-reader"></i> @u</li>
                            }
                        </ul>
                    </div>
                </div>

                <div class="class-info-bottom">
                    <button class="back-button"><i class="fa-solid fa-arrow-left"></i> Back</button>
                </div>
            </section>

            <!-- RIGHT SECTION -->
            <div class="right-column-task">
            <section class="material-container" id="materialContainer" data-material-id="@Model.MaterialId">
                <div class="material-scrollable">
                    <h2 class="material-name" id="materialName" contenteditable="false">@Model.MaterialName</h2>
                    <p class="material-description" id="materialDescription" contenteditable="false">
                        @Model.MaterialDescription
                    </p>

                    <!-- ATTACHMENTS FROM DATABASE -->
                    <div class="attachments-section">
                        <h3>Attached Files</h3>
                        <div class="attachments" id="attachmentList">
                            @if (Model.Attachments.Any())
                            {
                                @foreach (var file in Model.Attachments)
                                {
                                    <div class="attachment-box">
                                        <span class="attachment-name" data-filename="@file" data-contentid="@Model.MaterialId" title="Options for @file">@file</span>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="no-files">No files attached to this material.</p>
                            }
                        </div>
                    </div>
                </div>

                

                <!-- FIXED BOTTOM SECTION -->
                <div class="material-bottom" id="materialBottom">
                    <p class="posted-date" id="dateInfo">
                        Posted: @Model.PostedDate
                        @if (!string.IsNullOrWhiteSpace(Model.EditedDate))
                        {
                            <text> | Edited: @Model.EditedDate</text>
                        }
                    </p>
                    <div class="edit-controls" id="editControls" hidden>
                        <input type="file" id="replaceFileInput" accept="*/*" hidden />
                        <button class="btn" id="replaceFileBtn" title="Replace attached file"><i class="fa-solid fa-file-arrow-up"></i> Replace File</button>
                        <button class="btn save-btn" id="saveEditBtn">Save</button>
                        <button class="btn cancel-btn" id="cancelEditBtn">Cancel</button>
                    </div>
                </div>
            </section>
            <section class="public-comment-container" id="adminCommentContainer">
                <h3 class="public-comment-header">Comments</h3>
                <form id="adminCommentForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="contentId" value="@Model.MaterialId" />
                    <input type="hidden" name="classCode" value="@Model.ClassCode" />
                </form>
                <div class="public-comment-input">
                    <textarea id="adminCommentText" placeholder="Add a comment..."></textarea>
                    <button id="postAdminCommentBtn" class="post-comment-btn">Post</button>
                </div>
                <div class="public-comment-list" id="adminCommentList"></div>
            </section>
            </div>
        </main>

        <!-- ADMIN MAKE CHANGES BUTTON -->
        <div class="make-changes-wrap">
            <div class="make-changes-button" id="makeChangesButton" title="Make Changes">
                <i class="fa-solid fa-pen-to-square"></i>
            </div>

            <div class="admin-actions" id="adminActions">
                <div class="admin-action" data-action="edit">
                    <span class="label">Edit</span>
                    <button><i class="fa-solid fa-pen"></i></button>
                </div>
                <div class="admin-action" data-action="delete">
                    <span class="label">Delete</span>
                    <button><i class="fa-solid fa-trash"></i></button>
        </div>

        
    </div>
        </div>

        <!-- DELETE CONFIRMATION MODAL -->
        <div class="delete-modal" id="deleteModal">
            <div class="modal-content">
                <div class="modal-icon">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <h3>Delete Material?</h3>
                <p>This action <strong>cannot be undone</strong>. Are you sure you want to proceed?</p>
                <div class="modal-buttons">
                    <button class="btn confirm-delete" id="confirmDelete">
                        <i class="fa-solid fa-trash"></i> Delete
                    </button>
                    <button class="btn cancel-delete" id="cancelDelete">
                        <i class="fa-solid fa-xmark"></i> Cancel
                    </button>
                </div>
            </div>
        </div>

        <div id="toast" class="toast"></div>

        <script src="~/js/admindb/adminmaterial.js" asp-append-version="true"></script>
        <script>
            (function () {
                let attachmentMenuEl = null;
                function ensureMenu() {
                    if (!attachmentMenuEl) {
                        attachmentMenuEl = document.createElement('div');
                        attachmentMenuEl.className = 'attachment-menu';
                        attachmentMenuEl.style.display = 'none';
                        document.body.appendChild(attachmentMenuEl);
                    }
                }
                function closeMenu() {
                    if (attachmentMenuEl) attachmentMenuEl.style.display = 'none';
                }
                function openAttachmentMenu(target) {
                    ensureMenu();
                    const fileName = target.getAttribute('data-filename') || '';
                    const contentId = target.getAttribute('data-contentid') || '';
                    const viewUrl = '/AdminMaterial/ViewFile/' + encodeURIComponent(fileName) + '?contentId=' + encodeURIComponent(contentId);
                    const downloadUrl = '/AdminMaterial/DownloadFile/' + encodeURIComponent(fileName) + '?contentId=' + encodeURIComponent(contentId);
                    const box = target.closest('.attachment-box') || target;
                    const r = box.getBoundingClientRect();
                    attachmentMenuEl.innerHTML =
                        '<div class="menu-item open-new">Open in new tab</div>' +
                        '<div class="menu-divider"></div>' +
                        '<div class="menu-item download">Download</div>';
                    attachmentMenuEl.style.left = Math.min(r.right + 18, window.innerWidth - 220) + 'px';
                    attachmentMenuEl.style.top = Math.max(10, r.top - 4) + 'px';
                    attachmentMenuEl.style.display = 'block';
                    const openEl = attachmentMenuEl.querySelector('.open-new');
                    const dlEl = attachmentMenuEl.querySelector('.download');
                    openEl?.addEventListener('click', function (e) {
                        e.preventDefault();
                        e.stopPropagation();
                        window.open(viewUrl, '_blank', 'noopener');
                        closeMenu();
                    });
                    dlEl?.addEventListener('click', function (e) {
                        e.preventDefault();
                        e.stopPropagation();
                        window.location.href = downloadUrl;
                        closeMenu();
                    });
                }
                document.addEventListener('click', function (ev) {
                    const t = ev.target;
                    if (t && t.classList && t.classList.contains('attachment-name')) {
                        ev.preventDefault();
                        ev.stopPropagation();
                        openAttachmentMenu(t);
                        return;
                    }
                    if (attachmentMenuEl && attachmentMenuEl.style.display === 'block' && !attachmentMenuEl.contains(t)) {
                        closeMenu();
                    }
                });
                document.addEventListener('keydown', function (e) {
                    if (e.key === 'Escape') closeMenu();
                });
            })();
        </script>
        @{ 
            ViewBag.ClassCode = Model.ClassCode;
            ViewBag.CurrentPage = "assessment";
        }
        @await Html.PartialAsync("_AdminBottomBar")

    </div>
</body>
</html>
