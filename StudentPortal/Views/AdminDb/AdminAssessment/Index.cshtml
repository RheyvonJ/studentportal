@model SIA_IPT.Models.AdminAssessment.AdminAssessmentViewModel
@{
    ViewData["Title"] = "Admin Assessment";
    Layout = null;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link rel="stylesheet" href="~/css/admindb/adminassessment.css" />
<link rel="stylesheet" href="~/css/Shared/BottomBar.css" asp-append-version="true" />

<body data-class-code="@Model.ClassCode">
    <div class="page">
        <main class="class-container">

            <!-- LEFT: CLASS INFO -->
            <section class="class-info">
                <div class="class-banner" style="background:url('c:/Users/Vaughn/source/repos/StudentPortal/.vs/StudentPortal/FileContentIndex/30dbce06-8735-4efb-b780-868848a98c3d.vsidx') center/cover no-repeat;">
                    <div class="profile-initials" aria-hidden="true">@Model.InstructorInitials</div>
                    <div class="teacher-details">
                        <div class="teacher-name">@Model.InstructorName</div>
                        <div class="teacher-meta">
                            @Model.TeacherRole
                            @if (!string.IsNullOrWhiteSpace(Model.TeacherDepartment))
                            {
                                <text> | @Model.TeacherDepartment</text>
                            }
                        </div>
                        <div class="room-location">
                            @Model.RoomName
                            @if (!string.IsNullOrWhiteSpace(Model.FloorDisplay))
                            {
                                <text> • @Model.FloorDisplay</text>
                            }
                        </div>
                    </div>
                </div>

                <h2 class="subject-name">@Model.SubjectName</h2>
                <p class="subject-code">Subject Code: <span class="code-value">@Model.SubjectCode</span></p>
                <p class="class-code">Class Code: <span class="code-value">@Model.ClassCode</span></p>

                <div class="link-editor">
                    <label for="assessmentLinkInput">Assessment Link</label>
                    <div class="link-row">
                        <input id="assessmentLinkInput" type="text" value="@Model.LinkUrl" placeholder="https://..." />
                    </div>
                </div>

                <div class="recent-uploads">
                    <h3>Recent Assessments</h3>
                    <ul>
                        @foreach (var u in Model.RecentMaterials)
                        {
                            <li><i class="fa-solid fa-circle-question"></i> @u</li>
                        }
                    </ul>
                </div>

                <button class="back-button"><i class="fa-solid fa-arrow-left"></i> Back</button>
            </section>

            <!-- RIGHT COLUMN -->
            <div class="right-column">
                <section class="assessment-container" id="assessmentContainer" data-assessment-id="@Model.AssessmentId">
                    <div class="assessment-scrollable">
                        <h2 class="assessment-title" id="assessmentTitle" contenteditable="false">@Model.AssessmentTitle</h2>
                        <p class="assessment-description" id="assessmentDescription" contenteditable="false">@Model.AssessmentDescription</p>

                        <div class="attachments" id="attachmentList">
                            @foreach (var file in Model.Attachments)
                            {
                                <div class="attachment-box">
                                    <span class="attachment-name" data-filename="@file" data-contentid="@Model.AssessmentId" title="Options for @file">@file</span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="assessment-bottom" id="assessmentBottom">
                        <p class="posted-date" id="dateInfo">
                            Posted: @Model.PostedDate
                            @if (!string.IsNullOrWhiteSpace(Model.EditedDate))
                            {
                                <text> | Edited: @Model.EditedDate</text>
                            }
                            @if (!string.IsNullOrWhiteSpace(Model.Deadline) && Model.Deadline != "N/A")
                            {
                                <text> | Deadline: @Model.Deadline</text>
                            }
                        </p>
                    </div>
                </section>

                <!-- ANTI-CHEATING LOGS CONTAINER -->
                <section class="anti-cheat-container">
                    <!-- Top Section: Logs -->
                    <div class="logs-top">
                        <!-- Interaction Logs -->
                        <div class="logs-category">
                            <h3 class="category-header">Interaction</h3>
                            <div class="log-boxes">
                                <div class="log-box" data-log-type="copy">
                                    <span class="log-type">Copy</span>
                                    <span class="log-count" id="logCopy">@Model.LogCopy</span>
                                </div>
                                <div class="log-box" data-log-type="paste">
                                    <span class="log-type">Paste</span>
                                    <span class="log-count" id="logPaste">@Model.LogPaste</span>
                                </div>
                                <div class="log-box" data-log-type="inspect">
                                    <span class="log-type">Inspect</span>
                                    <span class="log-count" id="logInspect">@Model.LogInspect</span>
                                </div>
                            </div>
                        </div>

                        <!-- Omni-Focus Logs -->
                        <div class="logs-category">
                            <h3 class="category-header">Omni-Focus</h3>
                            <div class="log-boxes">
                                <div class="log-box" data-log-type="tabswitch">
                                    <span class="log-type">Tab Switch</span>
                                    <span class="log-count" id="logTabSwitch">@Model.LogTabSwitch</span>
                                </div>
                                <div class="log-box" data-log-type="openprograms">
                                    <span class="log-type">Open Programs</span>
                                    <span class="log-count" id="logOpenPrograms">@Model.LogOpenPrograms</span>
                                </div>
                                <div class="log-box" data-log-type="screenshare">
                                    <span class="log-type">Screen Share</span>
                                    <span class="log-count" id="logScreenShare">@Model.LogScreenShare</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Bottom Section: Assessment Validity -->

                </section>

                <!-- ===================== LOG LIST MODALS ===================== -->
                <!-- Template modal structure (re-used for all) -->
                @foreach (var modal in new[] {
                                "copy", "paste", "inspect",
                                "tabswitch", "openprograms", "screenshare" })
                {
                    <div id="modal-@modal" class="loglist-modal">
                        <div class="loglist-modal-content">
                            <span class="loglist-modal-close" data-close="@modal">&times;</span>
                            <h2 class="loglist-title" id="title-@modal"></h2>
                            <div class="loglist-body" id="list-@modal">
                                <!-- JS populates the activity list here -->
                            </div>
                        </div>
                    </div>
                }

            </div>
        </main>

        <!-- ADMIN MAKE CHANGES BUTTON -->
        <div class="make-changes-wrap">
            <div class="make-changes-button" id="makeChangesButton" title="Make Changes">
                <i class="fa-solid fa-pen-to-square"></i>
            </div>

            <div class="admin-actions" id="adminActions" aria-hidden="true">
                <div class="admin-action" data-action="edit">
                    <span class="label">Edit</span>
                    <button><i class="fa-solid fa-pen"></i></button>
                </div>
                <div class="admin-action" data-action="delete">
                    <span class="label">Delete</span>
                    <button><i class="fa-solid fa-trash"></i></button>
                </div>
            </div>
        </div>

        <!-- DELETE CONFIRMATION MODAL -->
        <div class="delete-modal" id="deleteModal">
            <div class="modal-content">
                <div class="modal-icon">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <h3>Delete Task?</h3>
                <p>This action <strong>cannot be undone</strong>. Are you sure you want to proceed?</p>
                <div class="modal-buttons">
                    <button class="btn confirm-delete" id="confirmDelete">
                        <i class="fa-solid fa-trash"></i> Delete
                    </button>
                    <button class="btn cancel-delete" id="cancelDelete">
                        <i class="fa-solid fa-xmark"></i> Cancel
                    </button>
                </div>
            </div>
        </div>
        <div id="toast" class="toast" aria-live="polite" role="status"></div>
        <div class="link-modal" id="linkModal" aria-hidden="true">
            <div class="link-modal-content">
                <h3 class="link-modal-title">Edit Assessment Link</h3>
                <input id="linkModalInput" type="text" value="@Model.LinkUrl" placeholder="https://..." />
                <div class="link-modal-buttons">
                    <button class="btn primary" id="linkModalSave">Save</button>
                    <button class="btn secondary" id="linkModalCancel">Cancel</button>
                </div>
            </div>
        </div>

        <script src="~/js/AdminDb/AdminAssessment.js" asp-append-version="true"></script>
        <script>
            (function () {
                let attachmentMenuEl = null;
                function ensureMenu() {
                    if (!attachmentMenuEl) {
                        attachmentMenuEl = document.createElement('div');
                        attachmentMenuEl.className = 'attachment-menu';
                        attachmentMenuEl.style.display = 'none';
                        document.body.appendChild(attachmentMenuEl);
                    }
                }
                function closeMenu() {
                    if (attachmentMenuEl) attachmentMenuEl.style.display = 'none';
                }
                function openAttachmentMenu(target) {
                    ensureMenu();
                    const fileName = target.getAttribute('data-filename') || '';
                    const contentId = target.getAttribute('data-contentid') || '';
                    const viewUrl = '/AdminAssessment/ViewFile/' + encodeURIComponent(fileName) + '?contentId=' + encodeURIComponent(contentId);
                    const downloadUrl = '/AdminAssessment/DownloadFile/' + encodeURIComponent(fileName) + '?contentId=' + encodeURIComponent(contentId);
                    const box = target.closest('.attachment-box') || target;
                    const r = box.getBoundingClientRect();
                    attachmentMenuEl.innerHTML =
                        '<div class="menu-item open-new">Open in new tab</div>' +
                        '<div class="menu-divider"></div>' +
                        '<div class="menu-item download">Download</div>';
                    attachmentMenuEl.style.left = Math.min(r.right + 18, window.innerWidth - 220) + 'px';
                    attachmentMenuEl.style.top = Math.max(10, r.top - 4) + 'px';
                    attachmentMenuEl.style.display = 'block';
                    const openEl = attachmentMenuEl.querySelector('.open-new');
                    const dlEl = attachmentMenuEl.querySelector('.download');
                    openEl?.addEventListener('click', function (e) {
                        e.preventDefault();
                        e.stopPropagation();
                        window.open(viewUrl, '_blank', 'noopener');
                        closeMenu();
                    });
                    dlEl?.addEventListener('click', function (e) {
                        e.preventDefault();
                        e.stopPropagation();
                        window.location.href = downloadUrl;
                        closeMenu();
                    });
                }
                document.addEventListener('click', function (ev) {
                    const t = ev.target;
                    if (t && t.classList && t.classList.contains('attachment-name')) {
                        ev.preventDefault();
                        ev.stopPropagation();
                        openAttachmentMenu(t);
                        return;
                    }
                    if (attachmentMenuEl && attachmentMenuEl.style.display === 'block' && !attachmentMenuEl.contains(t)) {
                        closeMenu();
                    }
                });
                document.addEventListener('keydown', function (e) {
                    if (e.key === 'Escape') closeMenu();
                });
            })();
        </script>
        @{
            ViewBag.CurrentPage = "assessment";
            ViewBag.Role = "Admin";
            ViewBag.ClassCode = Model.ClassCode;
            ViewBag.AdminName = Model.InstructorName;
            ViewBag.AdminInitials = Model.InstructorInitials;
        }
        @await Html.PartialAsync("_AdminBottomBar")

    </div>
</body>
