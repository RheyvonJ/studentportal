@model StudentPortal.Models.StudentDb.StudentAnnouncementViewModel
@{
    Layout = "_StudentLayout";
    ViewData["Title"] = $"{Model.SubjectName} - Announcement";
    ViewBag.CurrentPage = "subjects";
    ViewBag.EnableSidebarSlide = true;
    ViewBag.HideSidebar = true;
    ViewBag.HeaderTitle = Model.SubjectName;
    ViewBag.HeaderSubtext = $"{Model.SubjectCode} • {Model.ClassCode}";
    ViewBag.SuppressMobilePageContext = true;
    ViewBag.HeaderShowProfile = false;
    var announcementBackUrl = Model.CanManageAnnouncement
        ? Url.Action("Index", "AdminClass", new { id = Model.ClassCode })!
        : Url.Action("Index", "StudentClass", new { classCode = Model.ClassCode })!;
}
@section Styles {
    <link rel="stylesheet" href="~/css/StudentDb/StudentMaterial.css" asp-append-version="true" />
    <style>
        .student-announcement-footer .posted-date {
            margin: 0;
        }
        /* Delete sits below the white card, outside .material-container */
        .student-announcement-delete-below {
            display: flex;
            justify-content: flex-end;
            margin-top: 14px;
            width: 100%;
            box-sizing: border-box;
        }
        @if (Model.CanManageAnnouncement)
        {
            <text>
            .teacher-announce-btn-delete {
                padding: 10px 16px;
                border-radius: 12px;
                border: 1px solid rgba(185, 28, 28, 0.35);
                background: #fef2f2;
                color: #b91c1c;
                font-weight: 700;
                cursor: pointer;
                font-size: 0.9rem;
            }
            .teacher-announce-btn-delete:hover {
                background: #fee2e2;
            }
            </text>
        }
    </style>
}
<main class="student-class-shell student-announcement-page">
    <section class="class-container">
        <div class="student-announcement-back-row">
            <a href="@announcementBackUrl" class="student-announcement-back-btn">
                <i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Back
            </a>
        </div>
        <section class="class-info">
            <div class="class-info-top">
                <div class="class-banner">
                    <div class="profile-initials" aria-hidden="true">@Model.InstructorInitials</div>
                    <div class="teacher-details">
                        <div class="teacher-name">@Model.InstructorName</div>
                        <div class="teacher-meta">
                            @Model.InstructorRole
                            @if (!string.IsNullOrWhiteSpace(Model.TeacherDepartment))
                            {
                                <text> | @Model.TeacherDepartment</text>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(Model.RoomName) || !string.IsNullOrWhiteSpace(Model.FloorDisplay))
                        {
                            <div class="room-location">
                                @Model.RoomName
                                @if (!string.IsNullOrWhiteSpace(Model.FloorDisplay))
                                {
                                    <text> • @Model.FloorDisplay</text>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="class-info-middle-top">
                <h2 class="subject-name">@Model.SubjectName</h2>
                <p class="subject-code">Subject Code: <span class="code-value">@Model.SubjectCode</span></p>
                <p class="class-code">Class Code: <span class="code-value">@Model.ClassCode</span></p>
            </div>

            <div class="class-info-middle recent-material">
                <h3>Recent Announcements</h3>
                <ul>
                    @foreach (var item in Model.RecentAnnouncements)
                    {
                        <li><i class="fa-solid fa-bullhorn"></i> @item</li>
                    }
                </ul>
            </div>
        </section>

        <div class="right-column-task">
            <nav class="class-breadcrumb slsp-crumb-tabs" aria-label="Breadcrumb">
                <a class="slsp-crumb-tab" href="@Url.Content("~/studentdb/StudentDb")" title="Dashboard">
                    <i class="fa-solid fa-table-cells-large" aria-hidden="true"></i>
                    <span>Dashboard</span>
                </a>
                <span class="slsp-crumb-divider" aria-hidden="true"></span>
                <a class="slsp-crumb-tab" href="@announcementBackUrl" title="@Model.SubjectName">
                    <i class="fa-solid fa-book" aria-hidden="true"></i>
                    <span>@Model.SubjectCode</span>
                </a>
                <span class="slsp-crumb-divider" aria-hidden="true"></span>
                <span class="slsp-crumb-tab is-active" aria-current="page" title="@Model.Title">
                    <i class="fa-regular fa-file-lines" aria-hidden="true"></i>
                    <span>@Model.Title</span>
                </span>
            </nav>

            <section class="material-container" id="announcementContainer" data-content-id="@Model.ContentId" data-class-code="@Model.ClassCode">
                <div class="material-scrollable">
                    <h2 class="material-name">@Model.Title</h2>
                    @if (!string.IsNullOrWhiteSpace(Model.Description))
                    {
                        <p class="material-description">@Model.Description</p>
                    }

                    <div class="attachments-section">
                        <h3>Attached Files</h3>
                        <div class="attachments" id="attachmentList">
                            @if (Model.Files != null && Model.Files.Count > 0)
                            {
                                foreach (var f in Model.Files)
                                {
                                    <div class="attachment-box">
                                        @if (!string.IsNullOrWhiteSpace(f.FileUrl))
                                        {
                                            <a href="@f.FileUrl" target="_blank" rel="noopener" class="attachment-link">@f.FileName</a>
                                        }
                                        else
                                        {
                                            <span class="attachment-name">@f.FileName</span>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="no-files">No files attached to this announcement.</p>
                            }
                        </div>
                    </div>
                </div>

                <div class="material-bottom student-announcement-footer" id="announcementBottom">
                    <p class="posted-date" id="dateInfo">
                        Posted: @Model.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                        @if (!string.IsNullOrWhiteSpace(Model.EditedDate))
                        {
                            <text> | Edited: @Model.EditedDate</text>
                        }
                    </p>
                </div>
            </section>

            @if (Model.CanManageAnnouncement)
            {
                <div class="student-announcement-delete-below">
                    <button type="button" class="teacher-announce-btn-delete" id="teacherDeleteAnnouncementBtn" aria-haspopup="dialog">
                        Delete announcement
                    </button>
                </div>
            }
        </div>
    </section>
</main>

@if (Model.CanManageAnnouncement)
{
    <div id="teacherAnnDeleteConfirmBackdrop" class="slsp-confirm-backdrop" hidden aria-hidden="true"></div>
    <div id="teacherAnnDeleteConfirmModal" class="slsp-confirm-modal" role="dialog" aria-modal="true" aria-labelledby="teacherAnnDeleteConfirmTitle" aria-describedby="teacherAnnDeleteConfirmDesc" hidden>
        <div class="slsp-confirm-card">
            <div class="slsp-confirm-header">
                <div class="slsp-confirm-icon" aria-hidden="true"><i class="fa-solid fa-trash-can"></i></div>
                <h2 id="teacherAnnDeleteConfirmTitle" class="slsp-confirm-title">Delete announcement</h2>
                <p id="teacherAnnDeleteConfirmDesc" class="slsp-confirm-desc">Remove this announcement for all students in this class? This cannot be undone.</p>
            </div>
            <div class="slsp-confirm-actions">
                <button type="button" id="teacherAnnDeleteConfirmCancel" class="slsp-confirm-btn slsp-confirm-cancel">Cancel</button>
                <button type="button" id="teacherAnnDeleteConfirmOk" class="slsp-confirm-btn slsp-confirm-primary">Delete</button>
            </div>
        </div>
    </div>
}

<div id="toast" class="toast"></div>
@section Scripts {
    <script src="~/js/StudentDb/StudentClass.js" asp-append-version="true"></script>
    @if (Model.CanManageAnnouncement)
    {
        <script src="~/js/StudentDb/StudentAnnouncement.js" asp-append-version="true"></script>
    }
}
