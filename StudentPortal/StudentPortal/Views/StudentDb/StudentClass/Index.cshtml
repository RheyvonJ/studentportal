@model StudentPortal.Models.StudentDb.StudentClassViewModel
@{
    Layout = "_StudentLayout";
    ViewData["Title"] = $"{Model.SubjectName} - Class";
    ViewBag.CurrentPage = "subjects";
    ViewBag.EnableSidebarSlide = true;
    ViewBag.HideSidebar = true;
    ViewBag.HeaderTitle = "Class";
    ViewBag.HeaderSubtext = $"{Model.SectionName} • {Model.SubjectName} • {Model.SubjectCode} • {Model.ClassCode}";
    ViewBag.SuppressMobilePageContext = true;
    ViewBag.HeaderShowProfile = false;
    var recentUploads = Model.Contents
        .Where(c =>
        {
            var t = (c.Type ?? "").ToLowerInvariant();
            return t == "material" || t == "task" || t == "assessment";
        })
        .Take(3)
        .ToList();
}

@section Styles {
    <link rel="stylesheet" href="~/css/StudentDb/StudentClass.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminDb/AdminClass.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminDb/AdminAssessment.theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminDb/AdminClass.theme.css" asp-append-version="true" />
}

<main class="student-class-shell admin-class-page student-class-page" id="studentClassPage" data-student-dashboard-url="@Url.Content("~/studentdb/StudentDb")">
        <section class="class-container student-class-view-container">
            <div class="admin-class-topbar admin-class-topbar--breadcrumb-only">
                <nav class="admin-class-topbar-right class-breadcrumb aae-breadcrumb slsp-crumb-tabs" aria-label="Breadcrumb">
                    <a class="slsp-crumb-tab" href="@Url.Content("~/studentdb/StudentDb")" title="Dashboard">
                        <i class="fa-solid fa-table-cells-large" aria-hidden="true"></i>
                        <span>Dashboard</span>
                    </a>
                    <span class="slsp-crumb-divider" aria-hidden="true"></span>
                    <span class="slsp-crumb-tab is-active" aria-current="page" title="@Model.SubjectName">
                        <i class="fa-solid fa-book" aria-hidden="true"></i>
                        <span>@Model.SubjectCode</span>
                    </span>
                </nav>
            </div>
            <!-- LEFT SECTION (matches admin class-info / recent uploads) -->
            <section class="class-info aae-profile-card">
                <div class="aae-profile">
                    <div class="aae-profile-avatar" aria-hidden="true">@Model.InstructorInitials</div>
                    <div class="aae-profile-text">
                        <div class="aae-profile-name">@Model.InstructorName</div>
                        <div class="aae-profile-secondary">
                            @Model.InstructorRole
                            @if (!string.IsNullOrWhiteSpace(Model.TeacherDepartment))
                            {
                                <text> · @Model.TeacherDepartment</text>
                            }
                        </div>
                        <div class="aae-profile-secondary aae-profile-muted">
                            @Model.RoomName
                            @if (!string.IsNullOrWhiteSpace(Model.FloorDisplay))
                            {
                                <text> · @Model.FloorDisplay</text>
                            }
                        </div>
                    </div>
                </div>

                <div class="aae-subject-block">
                    <h2 class="aae-subject-title">@Model.SubjectName</h2>
                    <p class="aae-subject-line"><span class="aae-label">Subject code</span> <span class="aae-value">@Model.SubjectCode</span></p>
                    <p class="aae-subject-line"><span class="aae-label">Class code</span> <span class="aae-value">@Model.ClassCode</span></p>
                </div>

                <div class="aae-divider" role="presentation"></div>

                <div class="class-info-middle">
                    <div class="recent-uploads">
                        <h3 class="aae-aside-heading"><i class="fa-regular fa-clock"></i> Recent uploads</h3>
                        <ul>
                            @foreach (var content in recentUploads)
                            {
                                <li class="recent-upload-row" data-content-id="@(content.ContentId ?? "")">
                                    @if (!string.IsNullOrWhiteSpace(content.TargetAction) && content.TargetAction != "#")
                                    {
                                        <a class="recent-upload-link" href="@content.TargetAction">
                                            <i class="@content.IconClass" aria-hidden="true"></i>
                                            <span class="recent-title">@content.Title</span>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="recent-upload-static">
                                            <i class="@content.IconClass" aria-hidden="true"></i>
                                            <span class="recent-title">@content.Title</span>
                                        </span>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </section>

            <!-- RIGHT SECTION -->
            <section class="class-content" id="classContent">
                @foreach (var content in Model.Contents)
                {
                    <article class="content-card @content.Type" data-target="@content.TargetAction" data-content-id="@content.ContentId">
                        <div class="content-left">
                            <i class="@content.IconClass"></i>
                            <div class="content-info">
                                <h4 class="content-title">@content.Title</h4>
                                <p class="content-meta">@content.Meta</p>
                            </div>
                        </div>
                        @if ((content.Type == "task" || content.Type == "assessment") && !string.IsNullOrEmpty(content.Urgency))
                        {
                            <div class="content-right urgency @content.Urgency"></div>
                        }
                    </article>
                }
            </section>
        </section>
</main>

<div id="toast" class="toast"></div>

@section Scripts {
    <script src="~/js/StudentDb/StudentClass.js" asp-append-version="true"></script>
}
