@model StudentPortal.Models.LoginViewModel
@{
    Layout = null;
    ViewBag.Title = "Login - Sta. Lucia Senior High School";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/Login.css" />
</head>
<body>
    <div class="login-bg" aria-hidden="true"></div>
    <div class="login-overlay" aria-hidden="true"></div>
    <div class="login-wrapper">
        <div class="login-card">
            <div class="login-brand">
                <img src="~/images/SLSHS.png" alt="Sta. Lucia Senior High School Logo" class="brand-image" />
                <h1 class="brand-title">Sta. Lucia Senior High School</h1>
                <p class="brand-subtitle">Student Learning Portal</p>
            </div>

            <div class="login-form-section">
                <h2>Welcome back</h2>
                <p class="form-hint">Sign in with your credentials</p>

                @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { @class = "login-form", id = "loginForm" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.ReturnUrl)
                    <div class="input-group">
                        @Html.TextBoxFor(m => m.Email, new { placeholder = "Email address", @class = "form-input", type = "email", autocomplete = "email" })
                        @Html.ValidationMessageFor(m => m.Email, null, new { @class = "validation-msg" })
                    </div>
                    <div class="input-group">
                        <div class="password-field">
                            @Html.PasswordFor(m => m.Password, new { placeholder = "Password", @class = "form-input password-input", id = "loginPassword", autocomplete = "current-password" })
                            <button type="button" class="password-toggle" id="passwordToggle" aria-label="Show password" aria-pressed="false" tabindex="0">
                                <i class="fa-regular fa-eye" aria-hidden="true"></i>
                            </button>
                        </div>
                        @Html.ValidationMessageFor(m => m.Password, null, new { @class = "validation-msg" })
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="login-alert login-alert--error" role="alert">
                            <span class="login-alert-icon" aria-hidden="true"><i class="fa-solid fa-circle-exclamation"></i></span>
                            <div class="login-alert-body">
                                <strong class="login-alert-title">Sign-in failed</strong>
                                <p class="login-alert-text">@ViewBag.Error</p>
                            </div>
                        </div>
                    }

                    <button type="submit" class="btn-login">Sign in</button>
                }
            </div>

            <div class="login-footer">
                <div class="form-links">
                    <a href="@Url.Action("ForgotPassword", "Account")">Forgot password?</a>
                </div>
                @if (ViewBag.LastUpdatedUtc != null)
                {
                    <div style="margin-top:10px; font-size:12px; color:rgba(255,255,255,.72); text-align:center;">
                        Last updated: <strong style="color:rgba(255,255,255,.88); font-weight:600;">@ViewBag.LastUpdatedUtc</strong>
                    </div>
                }
            </div>
        </div>
    </div>
    <script src="~/js/Login.js"></script>
</body>
</html>
