@model StudentPortal.Models.AdminTask.AdminTaskViewModel
@{
    Layout = "_StudentLayout";
    ViewData["Title"] = $"{Model.TaskTitle} - Task";
    ViewBag.CurrentPage = "subjects";
    ViewBag.EnableSidebarSlide = true;
    ViewBag.HideSidebar = true;
    ViewBag.HeaderTitle = "Task";
    ViewBag.HeaderSubtext = $"{Model.SectionName} • {Model.SubjectName} • {Model.SubjectCode} • {Model.ClassCode}";
    ViewBag.SuppressMobilePageContext = true;
    ViewBag.HeaderShowProfile = false;
    ViewBag.AdminName = Model.InstructorName;
    ViewBag.AdminInitials = Model.InstructorInitials;
    ViewBag.ClassCode = Model.ClassCode;
    ViewBag.Role = "Professor";
    var taskStatusLabel = "Active";
    var taskStatusVariant = "active";
    if (Model.Deadline.HasValue)
    {
        var daysLeft = (Model.Deadline.Value.Date - DateTime.UtcNow.Date).TotalDays;
        if (daysLeft < 0)
        {
            taskStatusLabel = "Overdue";
            taskStatusVariant = "closed";
        }
        else if (daysLeft <= 3)
        {
            taskStatusLabel = "Due Soon";
            taskStatusVariant = "draft";
        }
    }
    var postedDisplay = Model.PostedDate.ToString("MMM d, yyyy");
    var editedDisplay = (Model.EditedDate.HasValue && Model.EditedDate.Value > Model.PostedDate)
        ? Model.EditedDate.Value.ToString("MMM d, yyyy")
        : string.Empty;
    var deadlineDisplay = Model.Deadline.HasValue ? Model.Deadline.Value.ToString("MMM d, yyyy") : "N/A";
    var deadlineIso = Model.Deadline.HasValue ? Model.Deadline.Value.ToString("yyyy-MM-dd") : string.Empty;
    var pastDeadlineUtc = Model.Deadline.HasValue && DateTime.UtcNow > Model.Deadline.Value;
}

@section Styles {
    <link rel="stylesheet" href="~/css/StudentDb/StudentClass.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminDb/AdminClass.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminDb/AdminAssessment.theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminDb/AdminClass.theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminDb/AdminTask.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminDb/AdminLateSubmissionPanel.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Shared/PublicComments.css" asp-append-version="true" />
    <style>
        .check-submission-modal,
        .delete-modal {
            z-index: 13020;
        }
        .make-changes-wrap {
            z-index: 12050;
        }
    </style>
}

<main class="student-class-shell admin-class-page admin-task-page" id="adminTaskPage" data-class-code="@Model.ClassCode" data-class-id="@Model.ClassId" data-task-max="@Model.TaskMaxGrade" data-dashboard-url="@Url.Content("~/professordb/ProfessorDb")">
    <section class="class-container admin-class-view-container">
        <div class="admin-class-topbar admin-class-topbar--breadcrumb-only">
            <nav class="admin-class-topbar-right class-breadcrumb aae-breadcrumb slsp-crumb-tabs" aria-label="Breadcrumb">
                <a class="slsp-crumb-tab" href="@Url.Content("~/professordb/ProfessorDb")" title="Dashboard">
                    <i class="fa-solid fa-table-cells-large" aria-hidden="true"></i>
                    <span>Dashboard</span>
                </a>
                <span class="slsp-crumb-divider" aria-hidden="true"></span>
                <a class="slsp-crumb-tab" href="@Url.Action("Index", "AdminClass", new { id = Model.ClassCode })" title="@Model.SubjectName">
                    <i class="fa-solid fa-book" aria-hidden="true"></i>
                    <span>@Model.SubjectCode</span>
                </a>
                <span class="slsp-crumb-divider" aria-hidden="true"></span>
                <span class="slsp-crumb-tab is-active" aria-current="page" title="@Model.TaskTitle">
                    <i class="fa-regular fa-file-lines" aria-hidden="true"></i>
                    <span>@Model.TaskTitle</span>
                </span>
            </nav>
        </div>

        <section class="class-info aae-profile-card">
            <div class="aae-profile">
                <div class="aae-profile-avatar" aria-hidden="true">@Model.InstructorInitials</div>
                <div class="aae-profile-text">
                    <div class="aae-profile-name">@Model.InstructorName</div>
                    <div class="aae-profile-secondary">
                        @Model.TeacherRole
                        @if (!string.IsNullOrWhiteSpace(Model.TeacherDepartment))
                        {
                            <text> · @Model.TeacherDepartment</text>
                        }
                    </div>
                    <div class="aae-profile-secondary aae-profile-muted">
                        @Model.RoomName
                        @if (!string.IsNullOrWhiteSpace(Model.FloorDisplay))
                        {
                            <text> · @Model.FloorDisplay</text>
                        }
                    </div>
                </div>
            </div>

            <div class="aae-subject-block">
                <h2 class="aae-subject-title">@Model.SubjectName</h2>
                <p class="aae-subject-line"><span class="aae-label">Subject code</span> <span class="aae-value">@Model.SubjectCode</span></p>
                <p class="aae-subject-line"><span class="aae-label">Class code</span> <span class="aae-value">@Model.ClassCode</span></p>
            </div>

            <div class="aae-divider" role="presentation"></div>

            <div class="class-info-middle">
                @if (Model.RecentTasks != null && Model.RecentTasks.Count > 0)
                {
                    <div class="recent-uploads">
                        <h3 class="aae-aside-heading"><i class="fa-regular fa-clock"></i> Recent tasks</h3>
                        <ul>
                            @foreach (var t in Model.RecentTasks)
                            {
                                <li class="recent-upload-row @(t.IsCurrent ? "is-current" : "")" data-content-id="@(t.ContentId ?? "")">
                                    @if (!string.IsNullOrWhiteSpace(t.ContentId))
                                    {
                                        <a class="recent-upload-link" href="@Url.Action("Index", "AdminTask", new { classCode = Model.ClassCode, contentId = t.ContentId })" title="@t.Title">
                                            <i class="fa-solid fa-file-pen" aria-hidden="true"></i>
                                            <span class="recent-title">@t.Title</span>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="recent-upload-static">
                                            <i class="fa-solid fa-file-pen" aria-hidden="true"></i>
                                            <span class="recent-title">@t.Title</span>
                                        </span>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </section>

        <section class="class-content admin-class-right-column" id="classContent" data-class-id="@Model.ClassId">
            <div class="admin-task-stack">
                <section class="task-container aae-assessment-card" id="taskContainer" data-task-id="@Model.TaskId">
                    <div class="task-scrollable aae-assessment-body">
                        <header class="aae-card-header">
                            <div class="aae-title-row">
                                <h2 class="task-title aae-assessment-name" id="taskTitle" contenteditable="false">@Model.TaskTitle</h2>
                                <span class="aae-status-badge aae-status-@taskStatusVariant" id="taskStatusBadge">@taskStatusLabel</span>
                            </div>
                        </header>

                        <p class="task-description aae-description" id="taskDescription" contenteditable="false">@Model.TaskDescription</p>

                        <div class="aae-divider soft" role="presentation"></div>

                        <div id="dateInfo" class="aae-meta-row"
                             data-posted="@postedDisplay"
                             data-edited="@editedDisplay"
                             data-deadline-display="@deadlineDisplay"
                             data-deadline-iso="@deadlineIso">
                            <div class="aae-meta-item">
                                <span class="aae-meta-icon" aria-hidden="true"><i class="fa-regular fa-calendar"></i></span>
                                <span class="aae-meta-label">Posted</span>
                                <span class="aae-meta-value">@postedDisplay</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(editedDisplay))
                            {
                                <div class="aae-meta-item">
                                    <span class="aae-meta-icon" aria-hidden="true"><i class="fa-regular fa-pen-to-square"></i></span>
                                    <span class="aae-meta-label">Edited</span>
                                    <span class="aae-meta-value">@editedDisplay</span>
                                </div>
                            }
                            <div class="aae-meta-item">
                                <span class="aae-meta-icon" aria-hidden="true"><i class="fa-regular fa-flag"></i></span>
                                <span class="aae-meta-label">Deadline</span>
                                <span class="aae-meta-value">@(deadlineDisplay == "N/A" ? "—" : deadlineDisplay)</span>
                            </div>
                        </div>

                        @if (Model.Deadline.HasValue)
                        {
                            var latePanelState = Model.IsSubmissionLockedForStudents ? "locked" : (Model.AllowSubmissionsPastDeadline && pastDeadlineUtc ? "late-open" : "open");
                            <div class="slsp-late-submission-card aae-submission-deadline-panel" id="submissionDeadlinePanel"
                                 data-task-id="@Model.TaskId"
                                 data-allow-late="@(Model.AllowSubmissionsPastDeadline ? "true" : "false")"
                                 data-locked="@(Model.IsSubmissionLockedForStudents ? "true" : "false")"
                                 data-state="@latePanelState">
                                <div class="slsp-late-submission-card__accent" aria-hidden="true"></div>
                                <div class="slsp-late-submission-card__inner">
                                    <div class="slsp-late-submission-card__head">
                                        <div class="slsp-late-submission-card__icon-wrap" aria-hidden="true">
                                            <i class="fa-solid fa-clock-rotate-left"></i>
                                        </div>
                                        <div class="slsp-late-submission-card__titles">
                                            <h3 class="slsp-late-submission-card__title">Submissions &amp; deadline</h3>
                                            <span class="slsp-late-submission-card__badge" id="submissionDeadlineBadge">
                                                @if (latePanelState == "locked")
                                                {
                                                    <text><i class="fa-solid fa-lock" aria-hidden="true"></i> Closed to students</text>
                                                }
                                                else if (latePanelState == "late-open")
                                                {
                                                    <text><i class="fa-solid fa-unlock-keyhole" aria-hidden="true"></i> Late submissions on</text>
                                                }
                                                else
                                                {
                                                    <text><i class="fa-regular fa-circle-check" aria-hidden="true"></i> Accepting work</text>
                                                }
                                            </span>
                                        </div>
                                    </div>
                                    <p class="slsp-late-submission-card__body" id="submissionDeadlineStatus">
                                        @if (Model.AllowSubmissionsPastDeadline && pastDeadlineUtc)
                                        {
                                            <text>Students may still turn in work even though the due date has passed. Use <strong>Stop late submissions</strong> when you want to close the window again, or edit the task to set a new deadline.</text>
                                        }
                                        else if (Model.IsSubmissionLockedForStudents)
                                        {
                                            <text>The due date has passed and the portal has <strong>stopped accepting</strong> new uploads. Choose <strong>Allow late submissions</strong> to reopen without changing the date, or edit the task to extend the deadline.</text>
                                        }
                                        else
                                        {
                                            <text>While before the deadline, students can submit from their task page. To give more time, use <strong>Make changes</strong> and update the deadline date.</text>
                                        }
                                    </p>
                                    <div class="slsp-late-submission-card__actions">
                                        <button type="button" class="slsp-late-btn slsp-late-btn--allow" id="allowLateSubmissionBtn" style="display:@(Model.IsSubmissionLockedForStudents ? "inline-flex" : "none")">
                                            <i class="fa-solid fa-unlock" aria-hidden="true"></i>
                                            Allow late submissions
                                        </button>
                                        <button type="button" class="slsp-late-btn slsp-late-btn--revoke" id="revokeLateSubmissionBtn" style="display:@(Model.AllowSubmissionsPastDeadline && pastDeadlineUtc ? "inline-flex" : "none")">
                                            <i class="fa-solid fa-lock" aria-hidden="true"></i>
                                            Stop late submissions
                                        </button>
                                    </div>
                                    <p class="slsp-late-submission-card__hint" id="submissionDeadlineHint">
                                        <i class="fa-regular fa-lightbulb" aria-hidden="true"></i>
                                        <span>Tip: extending the deadline in edit mode updates the date students see; allowing late work keeps the same date but opens the dropbox.</span>
                                    </p>
                                </div>
                            </div>
                        }

                        <div class="aae-divider soft" role="presentation"></div>

                        <section class="attachments-section aae-files-section">
                            <h3 class="aae-section-heading"><i class="fa-regular fa-file-lines"></i> Attached files</h3>
                            <div id="attachmentDropzone" class="aae-dropzone @(Model.Attachments.Any() ? "has-files" : "")">
                                <div class="attachments aae-attachments" id="attachmentList">
                                    @foreach (var a in Model.Attachments)
                                    {
                                        <div class="attachment-box aae-file-chip" data-file-label="@a">
                                            <a href="#" class="attachment-name" data-filename="@a" data-taskid="@Model.TaskId" title="Open @a">@a</a>
                                        </div>
                                    }
                                </div>
                                @if (!Model.Attachments.Any())
                                {
                                    <div class="aae-empty-files" id="attachmentEmptyState">
                                        <div class="aae-empty-icon" aria-hidden="true"><i class="fa-regular fa-folder-open"></i></div>
                                        <p class="aae-empty-title">No files yet</p>
                                        <p class="aae-empty-hint">Use <strong>Replace file</strong> while editing to add an attachment.</p>
                                    </div>
                                }
                            </div>
                        </section>
                    </div>

                    <div class="edit-controls" id="editControls" hidden>
                        <input type="file" id="replaceFileInput" accept="*/*" hidden />
                        <button type="button" class="btn" id="replaceFileBtn" title="Replace attached file"><i class="fa-solid fa-file-arrow-up"></i> Replace File</button>
                        <button type="button" class="btn save-btn" id="saveEditBtn">Save</button>
                        <button type="button" class="btn cancel-btn" id="cancelEditBtn">Cancel</button>
                    </div>
                </section>

                <section class="submitted-container" id="submittedContainer">
                    <div class="submitted-top">
                        <h3>Submissions</h3>
                        <div class="submitted-controls">
                            <div class="controls-left">
                                <input id="searchStudents" class="input search-input" placeholder="Search students...">
                            </div>
                            <div class="controls-right">
                                <div class="stat-box">
                                    <span class="label">Submitted</span>
                                    <span class="value"><span id="submittedCount">@Model.Submissions?.FindAll(s => s.Submitted).Count</span>/<span id="totalStudents">@Model.Submissions?.Count</span></span>
                                </div>
                                @{
                                    var maxGrade = Model.TaskMaxGrade > 0 ? Model.TaskMaxGrade : 100;
                                    var points = (Model.Submissions ?? new List<StudentPortal.Models.AdminTask.TaskSubmission>())
                                        .Select(s =>
                                        {
                                            var g = (s.Grade ?? string.Empty).Trim();
                                            if (string.IsNullOrWhiteSpace(g)) return (double?)null;
                                            if (g.Contains("/"))
                                            {
                                                var parts = g.Split('/');
                                                if (parts.Length >= 1 && double.TryParse(parts[0], out var got)) return (double?)got;
                                                return (double?)null;
                                            }
                                            if (g.EndsWith("%"))
                                            {
                                                var pctText = g.Substring(0, g.Length - 1);
                                                if (double.TryParse(pctText, out var pct)) return (double?)(maxGrade * (pct / 100d));
                                                return (double?)null;
                                            }
                                            if (double.TryParse(g, out var raw)) return (double?)raw;
                                            return (double?)null;
                                        })
                                        .Where(v => v.HasValue)
                                        .Select(v => v!.Value)
                                        .ToList();
                                    var gradeAvg = points.Count > 0 ? points.Average() : 0;
                                }
                                <div class="stat-box">
                                    <span class="label">Average</span>
                                    <span class="value"><span id="gradeAvg">@gradeAvg.ToString("0.##")</span>/<span id="gradeAvgMax">@maxGrade</span></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="submitted-list" id="submittedList" role="table" aria-label="Submitted students">
                        <div class="submitted-row header" role="row">
                            <div class="col name-col">Student Name</div>
                            <div class="col status-col">Completion Status</div>
                        </div>

                        @foreach (var s in Model.Submissions)
                        {
                            <div class="submitted-row" role="row" data-id="@s.Id" data-grade="@(s.Grade ?? "")">
                                <div class="col name-col">@s.FullName</div>
                                <div class="col status-col">
                                    @if (s.Submitted)
                                    {
                                        <span class="status-pill submitted">Submitted (@s.SubmittedAt?.ToString("MMM d"))</span>
                                    }
                                    else
                                    {
                                        <span class="status-pill missing">Missing</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </section>

                <section class="public-comment-container" id="adminCommentContainer">
                    <h3 class="public-comment-header">Comments</h3>
                    <form id="adminCommentForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="taskId" value="@Model.TaskId" />
                        <input type="hidden" name="classCode" value="@Model.ClassCode" />
                    </form>
                    <div class="public-comment-input">
                        <textarea id="adminCommentText" placeholder="Add a class comment..."></textarea>
                        <button type="button" id="postAdminCommentBtn" class="post-comment-btn">Post</button>
                    </div>
                    <div class="public-comment-list" id="adminCommentList"></div>
                </section>

                <form id="adminGradeForm" style="display:none">
                    @Html.AntiForgeryToken()
                </form>

                <div class="check-submission-modal" id="checkSubmissionModal">
                    <div class="check-submission-content">
                        <div class="check-header">
                            <h3 id="modalStudentName">Student Name</h3>
                            <div class="points-box">
                                @* type=text avoids browser max/min clamping while typing (e.g. 100 vs 10) *@
                                <input type="text" id="pointsEarned" class="points-earned-input" inputmode="decimal" autocomplete="off" placeholder="0" aria-label="Points earned"> /
                                <span id="pointsMax">@Model.TaskMaxGrade</span>
                            </div>
                        </div>

                        <div class="attachment-box-area" id="modalAttachments"></div>

                        <div class="comment-display">
                            <label>Private Comment</label>
                            <div id="privateCommentDisplay" class="comment-box">No comment provided.</div>
                        </div>

                        <textarea id="remarks" class="input-area" placeholder="Remarks..."></textarea>

                        <div class="modal-actions">
                            <button type="button" class="btn save-grade">Save</button>
                            <button type="button" class="btn cancel-grade" id="closeSubmissionModal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </section>
</main>

<!-- In-page file viewer (Admin Task) -->
<div id="atFileViewer" class="sm-file-viewer" style="display:none;">
    <div class="sm-file-dialog">
        <div class="sm-file-header">
            <div id="atFileTitle" class="sm-file-title">File</div>
            <a id="atOpenNewTab" href="#" rel="noopener" class="sm-file-action sm-file-open">Open in new tab</a>
            <a id="atDownload" href="#" download class="sm-file-action sm-file-download">Download</a>
            <button type="button" id="atCloseViewer" class="sm-file-close" aria-label="Close">×</button>
        </div>
        <div id="atViewerBody" class="sm-file-body"></div>
    </div>
</div>

<!-- Open confirmation modal -->
<div id="atOpenConfirmBackdrop" class="slsp-confirm-backdrop" hidden aria-hidden="true"></div>
<div id="atOpenConfirmModal" class="slsp-confirm-modal" role="dialog" aria-modal="true" aria-labelledby="atOpenConfirmTitle" aria-describedby="atOpenConfirmDesc" hidden>
    <div class="slsp-confirm-card">
        <div class="slsp-confirm-header">
            <div class="slsp-confirm-icon" aria-hidden="true"><i class="fa-solid fa-up-right-from-square"></i></div>
            <h2 id="atOpenConfirmTitle" class="slsp-confirm-title">Open file</h2>
            <p id="atOpenConfirmDesc" class="slsp-confirm-desc">Do you want to open this file in a new tab?</p>
        </div>
        <div class="slsp-confirm-actions">
            <button type="button" id="atOpenConfirmCancel" class="slsp-confirm-btn slsp-confirm-cancel">Cancel</button>
            <button type="button" id="atOpenConfirmOk" class="slsp-confirm-btn slsp-confirm-primary">Open</button>
        </div>
    </div>
</div>

<!-- Download confirmation modal -->
<div id="atDownloadConfirmBackdrop" class="slsp-confirm-backdrop" hidden aria-hidden="true"></div>
<div id="atDownloadConfirmModal" class="slsp-confirm-modal" role="dialog" aria-modal="true" aria-labelledby="atDownloadConfirmTitle" aria-describedby="atDownloadConfirmDesc" hidden>
    <div class="slsp-confirm-card">
        <div class="slsp-confirm-header">
            <div class="slsp-confirm-icon" aria-hidden="true"><i class="fa-solid fa-download"></i></div>
            <h2 id="atDownloadConfirmTitle" class="slsp-confirm-title">Download file</h2>
            <p id="atDownloadConfirmDesc" class="slsp-confirm-desc">Do you want to download this file?</p>
        </div>
        <div class="slsp-confirm-actions">
            <button type="button" id="atDownloadConfirmCancel" class="slsp-confirm-btn slsp-confirm-cancel">Cancel</button>
            <button type="button" id="atDownloadConfirmOk" class="slsp-confirm-btn slsp-confirm-primary">Download</button>
        </div>
    </div>
</div>

<div class="make-changes-wrap">
    <div class="make-changes-button" id="makeChangesButton" title="Make Changes">
        <i class="fa-solid fa-pen-to-square"></i>
    </div>

    <div class="admin-actions" id="adminActions" aria-hidden="true">
        <div class="admin-action" data-action="edit">
            <span class="label">Edit</span>
            <button type="button"><i class="fa-solid fa-pen"></i></button>
        </div>
        <div class="admin-action" data-action="delete">
            <span class="label">Delete</span>
            <button type="button"><i class="fa-solid fa-trash"></i></button>
        </div>
    </div>
</div>

<div class="delete-modal" id="deleteModal">
    <div class="modal-content">
        <div class="modal-icon">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </div>
        <h3>Delete Task?</h3>
        <p>This action <strong>cannot be undone</strong>. Are you sure you want to proceed?</p>
        <div class="modal-buttons">
            <button type="button" class="btn confirm-delete" id="confirmDelete">
                <i class="fa-solid fa-trash"></i> Delete
            </button>
            <button type="button" class="btn cancel-delete" id="cancelDelete">
                <i class="fa-solid fa-xmark"></i> Cancel
            </button>
        </div>
    </div>
</div>

<div class="grade-confirm-modal" id="gradeConfirmModal" role="dialog" aria-modal="true" aria-labelledby="gradeConfirmTitle">
    <div class="grade-confirm-panel">
        <h3 id="gradeConfirmTitle">Confirm Grade</h3>
        <p class="grade-confirm-line">You are about to give:</p>
        <p class="grade-confirm-value" id="gradeConfirmScore">0 / 0</p>
        <p class="grade-confirm-line">to</p>
        <p class="grade-confirm-value" id="gradeConfirmStudent">Student Name</p>
        <p class="grade-confirm-line">for task</p>
        <p class="grade-confirm-value" id="gradeConfirmTask">Task Name</p>
        <div class="grade-confirm-actions">
            <button type="button" class="btn grade-confirm-cancel" id="gradeConfirmCancel">
                Go Back
            </button>
            <button type="button" class="btn grade-confirm-ok" id="gradeConfirmOk">
                Confirm
            </button>
        </div>
    </div>
</div>

<div id="toast" class="toast" aria-live="polite" role="status"></div>

@section Scripts {
    <script src="~/js/AdminDb/AdminTask.js" asp-append-version="true"></script>
}
