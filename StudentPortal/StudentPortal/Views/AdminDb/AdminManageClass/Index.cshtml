@model StudentPortal.Models.AdminDb.AdminManageClassViewModel
@{
    Layout = "_StudentLayout";
    ViewData["Title"] = $"{Model.SubjectName} — Class Management";
    ViewBag.CurrentPage = "subjects";
    ViewBag.EnableSidebarSlide = true;
    ViewBag.HideSidebar = true;
    ViewBag.HeaderTitle = "Class Management";
    ViewBag.HeaderSubtext = $"{Model.SectionName} • {Model.SubjectName} • {Model.SubjectCode} • {Model.ClassCode}";
    ViewBag.SuppressMobilePageContext = true;
    ViewBag.HeaderShowProfile = false;
    ViewBag.ClassCode = Model.ClassCode;
    ViewBag.Role = "Professor";
    var adminName = ViewBag.AdminName as string ?? "Professor";
    var adminInitials = ViewBag.AdminInitials as string ?? "PR";
    var adminClassUrl = Url.Content($"~/AdminClass/{Model.ClassCode}");
}

@section Styles {
    <link rel="stylesheet" href="~/css/StudentDb/StudentClass.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminDb/AdminClass.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminDb/AdminAssessment.theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminDb/AdminClass.theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminDb/AdminManageClass.css" asp-append-version="true" />
    <style>
        .admin-manage-class-page .focus-modal,
        .admin-manage-class-page #focus-modal,
        .admin-manage-class-page #unenroll-modal,
        .admin-manage-class-page #meet-modal,
        .admin-manage-class-page #manage-meeting-modal,
        .admin-manage-class-page #end-meet-confirm-modal {
            z-index: 13010;
        }
        .admin-manage-class-page .focus-progress {
            z-index: 13005;
        }
    </style>
}

<main class="student-class-shell admin-class-page admin-manage-class-page"
      id="adminManageClassPage"
      data-class-code="@Model.ClassCode"
      data-dashboard-url="@Url.Content("~/professordb/ProfessorDb")"
      data-admin-class-url="@adminClassUrl"
      data-meeting-id="@(ViewBag.MeetingId ?? "")"
      data-meeting-created-at="@(ViewBag.MeetingCreatedAt != null ? ((DateTime)ViewBag.MeetingCreatedAt).ToString("O") : "")"
      data-meeting-join-url="@(ViewBag.MeetingJoinUrl ?? "")">
    <section class="class-container admin-manage-class-container">
        @* Row 1: full-width breadcrumb (matches Admin Class / Material) *@
        <div class="admin-class-topbar admin-class-topbar--breadcrumb-only">
            <nav class="admin-class-topbar-right class-breadcrumb aae-breadcrumb slsp-crumb-tabs" aria-label="Breadcrumb">
                <a class="slsp-crumb-tab" href="@Url.Content("~/professordb/ProfessorDb")" title="Dashboard">
                    <i class="fa-solid fa-table-cells-large" aria-hidden="true"></i>
                    <span>Dashboard</span>
                </a>
                <span class="slsp-crumb-divider" aria-hidden="true"></span>
                <a class="slsp-crumb-tab" href="@adminClassUrl" title="@Model.SubjectName">
                    <i class="fa-solid fa-book" aria-hidden="true"></i>
                    <span>@Model.SubjectCode</span>
                </a>
                <span class="slsp-crumb-divider" aria-hidden="true"></span>
                <span class="slsp-crumb-tab is-active" aria-current="page" title="Manage class">
                    <i class="fa-solid fa-users-gear" aria-hidden="true"></i>
                    <span>Manage</span>
                </span>
            </nav>
        </div>

        <section class="class-content admin-class-right-column admin-manage-class-content" id="manageClassContent">
            <span id="manageClassTeacherName" class="sr-only">@adminName</span>
            <span id="sidebarStudentCount" class="sr-only">@Model.Students.Count</span>
            <div class="admin-manage-class-inner">
                <section class="seat-grid-container" aria-label="Seating chart">
                    <div class="top-bar">
                        <div class="top-left">
                            <h2 class="page-title admin-manage-toolbar-title">Seating &amp; tools</h2>
                        </div>

                        <div class="top-right">
                            <div class="admin-manage-desktop-seating-only" aria-hidden="false">
                            <div class="grid-controls" title="Rows × Columns">
                                <div class="grid-field">
                                    <input id="seat-rows" type="number" min="1" max="20" value="4" aria-label="Rows" />
                                    <div class="input-tooltip" role="tooltip">Rows</div>
                                </div>
                                <span class="times">×</span>
                                <div class="grid-field">
                                    <input id="seat-cols" type="number" min="1" max="20" value="6" aria-label="Columns" />
                                    <div class="input-tooltip" role="tooltip">Columns</div>
                                </div>
                            </div>
                            </div>
                            <button id="attendance-btn" class="btn small primary" type="button">
                                <i class="fa-solid fa-clipboard-user"></i> Attendance
                            </button>

                            @* Active meeting: primary = Join (opens Jitsi in new tab), secondary = End. No meeting: Create only. *@
                            @if (ViewBag.HasMeeting == true)
                            {
                                var scheduledAt = ViewBag.MeetingScheduledAt as DateTime?;
                                <button id="join-meet-btn"
                                        type="button"
                                        class="btn small primary"
                                        data-meet-url="@ViewBag.MeetingJoinUrl"
                                        title="Open the class meeting (Jitsi) in a new tab">
                                    <i class="fa-solid fa-video" aria-hidden="true"></i> Join Meeting
                                </button>
                                <button id="end-meet-btn" type="button" class="btn small danger" title="End this meeting for the class. You can create a new meeting afterward.">
                                    <i class="fa-solid fa-phone-slash" aria-hidden="true"></i> End Meeting
                                </button>
                                @if (scheduledAt.HasValue)
                                {
                                    <span class="meet-schedule-label" title="Meeting scheduled start">
                                        <i class="fa-regular fa-calendar-days" aria-hidden="true"></i>
                                        <span class="meet-schedule-text">
                                            <span class="meet-schedule-key">Scheduled</span>
                                            <span class="meet-schedule-datetime">@scheduledAt.Value.ToString("MMM d, yyyy h:mm tt")</span>
                                        </span>
                                    </span>
                                }
                            }
                            else
                            {
                                <button id="create-meet-btn" type="button" class="btn small primary">
                                    <i class="fa-solid fa-video"></i> Create Meet
                                </button>
                            }

                            <button id="export-btn" type="button" class="btn small primary">
                                <i class="fa-solid fa-download"></i> Preview/Download
                            </button>
                        </div>
                    </div>

                    <div class="section-info">
                        <h3 class="section-name">Section: @Model.SectionName</h3>
                        <div class="student-count" id="studentCount">Students: @Model.Students.Count</div>
                    </div>

                    <div class="admin-manage-seating-scroll admin-manage-desktop-seating-only" aria-hidden="false">
                        <div id="seating-grid" class="seating-grid admin-manage-seat-grid" aria-label="Seating chart" role="grid"></div>
                    </div>
                </section>

                <section class="column-container">
                    <div class="class-list-container">
                        <div class="list-header">
                            <h3><i class="fa-solid fa-users-line"></i> Class List</h3>
                            <div class="search-box">
                                <input type="text" id="classSearch" placeholder="Search student..." />
                                <i class="fa-solid fa-magnifying-glass"></i>
                            </div>
                        </div>
                        <div id="student-list" class="class-list">
                            @if (Model.Students != null && Model.Students.Count > 0)
                            {
                                foreach (var s in Model.Students)
                                {
                                    var statusLower = (s.Status ?? "").ToLower();
                                    var name = s.StudentName ?? "";
                                    var parts = name.Split(' ', System.StringSplitOptions.RemoveEmptyEntries);
                                    var initials = parts.Length > 0 ? (parts[0].Substring(0, 1) + (parts.Length > 1 ? parts[^1].Substring(0, 1) : "")).ToUpper() : "";
                                    var attClass = statusLower == "present" ? "present" : statusLower == "late" ? "late" : statusLower == "absent" ? "absent" : "";
                                    <div class="student-card @attClass" data-student-id="@s.Id" data-student-email="@s.StudentEmail" data-student-name="@name">
                                        <div class="student-photo avatar">@initials</div>
                                        <div class="student-info">
                                            <div class="student-name">@s.StudentName</div>
                                            <div class="student-email">@s.StudentEmail</div>
                                            <div class="student-id">ID: @s.Id</div>
                                        </div>
                                        <div class="student-card-actions">
                                            @{
                                                var stLabel = (s.Status ?? "").Trim();
                                                var stClass = statusLower == "present" ? "status-present" : statusLower == "late" ? "status-late" : statusLower == "absent" ? "status-absent" : "";
                                            }
                                            <span class="student-status seat-status @stClass">@stLabel</span>
                                            <button type="button" class="student-card-more" data-id="@s.Id" data-student-id="@s.Id" data-student-email="@s.StudentEmail" data-student-name="@name" aria-haspopup="true" aria-label="Student actions">
                                                <i class="fa-solid fa-ellipsis-vertical" aria-hidden="true"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="no-students">No approved students yet.</div>
                            }
                        </div>
                    </div>

                    <div class="class-request-container">
                        <div class="request-header">
                            <h3><i class="fa-solid fa-user-plus"></i> Join Requests</h3>
                        </div>
                        <div id="join-request-list" class="request-list">
                            @if (Model.JoinRequests != null && Model.JoinRequests.Count > 0)
                            {
                                foreach (var req in Model.JoinRequests)
                                {
                                    var dateStr = req.RequestedAt.ToLocalTime().ToString("g");
                                    var name = req.StudentName ?? "";
                                    var parts = name.Split(' ', System.StringSplitOptions.RemoveEmptyEntries);
                                    var initials = parts.Length > 0 ? (parts[0].Substring(0, 1) + (parts.Length > 1 ? parts[^1].Substring(0, 1) : "")).ToUpper() : "";
                                    <div class="request-item">
                                        <div class="request-photo">@initials</div>
                                        <div class="request-info">
                                            <div class="request-name">@req.StudentName</div>
                                            <div class="request-meta">(@Model.SectionName) • @dateStr</div>
                                        </div>
                                        <div class="request-actions">
                                            <button type="button" class="approve-btn btn accept"
                                                    data-id="@req.Id"
                                                    data-name="@req.StudentName"
                                                    data-class-code="@req.ClassCode"
                                                    data-student-email="@req.StudentEmail">Accept</button>
                                            <button type="button" class="reject-btn btn deny" data-id="@req.Id">Deny</button>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="no-requests">No pending join requests.</div>
                            }
                        </div>
                    </div>
                </section>
            </div>
        </section>
    </section>

    <div id="toast" class="toast" aria-live="polite" role="status"></div>

    <div id="focus-progress" class="focus-progress" style="display:none;">
    <div class="progress-text">Focus Progress: <span id="progress-text">0 / 0</span></div>
    <div class="progress-bar"><div id="progress-fill" class="progress-fill"></div></div>
</div>

<div id="focus-modal" class="focus-modal">
    <div class="focus-modal-content">
        <span class="close" id="close-focus-modal">&times;</span>
        <img id="focus-photo" class="focus-photo" src="" alt="Student Photo">
        <div id="focus-initials" class="focus-initials avatar" style="display:none;">NA</div>
        <div id="focus-name" class="focus-name">Student Name</div>
        <div class="focus-buttons">
            <button type="button" id="mark-absent" class="btn small danger"><i class="fa-solid fa-xmark"></i> Absent</button>
            <button type="button" id="mark-late" class="btn small warning"><i class="fa-solid fa-clock"></i> Late</button>
            <button type="button" id="mark-present" class="btn small success"><i class="fa-solid fa-check"></i> Present</button>
        </div>
    </div>
</div>

<div id="unenroll-modal" class="focus-modal">
    <div class="focus-modal-content">
        <span class="close" id="close-unenroll-modal">&times;</span>
        <img id="unenroll-photo" class="focus-photo" src="" alt="Student Photo">
        <div id="unenroll-initials" class="focus-initials avatar" style="display:none;">NA</div>
        <div class="focus-name" id="unenroll-title">Un-enroll Student</div>
        <div id="unenroll-name" class="request-name"></div>
        <div id="unenroll-email" class="request-meta"></div>
        <div class="focus-buttons">
            <button type="button" id="cancel-unenroll" class="btn small">Cancel</button>
            <button type="button" id="confirm-unenroll" class="btn small danger">Un-enroll</button>
        </div>
    </div>
</div>

<div id="meet-modal" class="focus-modal meet-dialog-overlay">
    <div class="focus-modal-content meet-dialog-content" role="dialog" aria-modal="true" aria-labelledby="meet-modal-title">
        <span class="close" id="close-meet-modal" aria-label="Close">&times;</span>
        <div class="meet-dialog-header">
            <div class="meet-dialog-icon" aria-hidden="true"><i class="fa-solid fa-video"></i></div>
            <h2 class="meet-dialog-title" id="meet-modal-title">Create online meeting</h2>
        </div>
        <div class="meet-dialog-body">
            <div class="meet-dialog-fields">
                <div class="meet-dialog-field">
                    <label class="meet-dialog-label" for="meet-title">Title <span class="meet-dialog-optional">(optional)</span></label>
                    <input id="meet-title" class="meet-dialog-input" type="text" placeholder="e.g. Weekly review" autocomplete="off" />
                </div>
                <div class="meet-dialog-field">
                    <label class="meet-dialog-label" for="meet-schedule">Schedule <span class="meet-dialog-optional">(optional)</span></label>
                    <input id="meet-schedule" class="meet-dialog-input" type="datetime-local" />
                </div>
            </div>
        </div>
        <div class="meet-dialog-footer">
            <button type="button" id="cancel-meet" class="btn small meet-dialog-btn-secondary">Cancel</button>
            <button type="button" id="confirm-meet" class="btn small primary meet-dialog-btn-primary">
                <i class="fa-solid fa-video" aria-hidden="true"></i> Create &amp; Email
            </button>
        </div>
    </div>
</div>

<div id="manage-meeting-modal" class="focus-modal" style="display:none;">
    <div class="focus-modal-content manage-meeting-content">
        <span class="close" id="close-manage-meeting-modal">&times;</span>
        <div class="focus-name"><i class="fa-solid fa-video"></i> Manage meeting</div>
        <div class="meeting-duration-box">
            <span class="meeting-duration-label">Meeting running time</span>
            <span id="meeting-duration-value" class="meeting-duration-value">00:00:00</span>
        </div>
        <div class="focus-buttons manage-meeting-buttons">
            <button type="button" id="manage-meeting-join-btn" class="btn primary">
                <i class="fa-solid fa-video"></i> Join meeting
            </button>
            <button type="button" id="manage-meeting-stop-btn" class="btn small danger">
                <i class="fa-solid fa-stop"></i> Stop meeting
            </button>
        </div>
    </div>
</div>

<div id="end-meet-confirm-modal" class="focus-modal meet-dialog-overlay" style="display:none;" role="dialog" aria-modal="true" aria-labelledby="end-meet-confirm-title" aria-hidden="true">
    <div class="focus-modal-content meet-dialog-content meet-dialog-content--confirm">
        <button type="button" class="close" id="end-meet-confirm-close" aria-label="Close">&times;</button>
        <div class="meet-dialog-header">
            <div class="meet-dialog-icon meet-dialog-icon--danger" aria-hidden="true"><i class="fa-solid fa-phone-slash"></i></div>
            <h2 class="meet-dialog-title" id="end-meet-confirm-title">End meeting for this class?</h2>
        </div>
        <div class="meet-dialog-body">
            <p class="meet-dialog-desc" id="end-meet-confirm-desc">
                The Jitsi room will be cleared from this class. You can create a new meeting afterward.
            </p>
        </div>
        <div class="meet-dialog-footer">
            <button type="button" id="end-meet-confirm-cancel" class="btn small meet-dialog-btn-secondary">Cancel</button>
            <button type="button" id="end-meet-confirm-ok" class="btn small danger meet-dialog-btn-danger">
                <i class="fa-solid fa-phone-slash" aria-hidden="true"></i> End meeting
            </button>
        </div>
    </div>
</div>
</main>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="~/js/AdminDb/AdminManageClass.js" asp-append-version="true"></script>
}
