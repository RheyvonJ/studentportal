@model StudentPortal.Models.AdminMaterial.AdminMaterialViewModel
@{
    Layout = "_StudentLayout";
    ViewData["Title"] = $"{Model.MaterialName} - Material";
    ViewBag.CurrentPage = "subjects";
    ViewBag.EnableSidebarSlide = true;
    ViewBag.HideSidebar = true;
    ViewBag.HeaderTitle = "Material";
    ViewBag.HeaderSubtext = $"{Model.SectionName} • {Model.SubjectName} • {Model.SubjectCode} • {Model.ClassCode}";
    ViewBag.SuppressMobilePageContext = true;
    ViewBag.HeaderShowProfile = false;
    ViewBag.AdminName = Model.InstructorName;
    ViewBag.AdminInitials = Model.InstructorInitials;
    ViewBag.ClassCode = Model.ClassCode;
    ViewBag.Role = "Professor";
    var postedDisplay = Model.PostedDate;
    var editedDisplay = !string.IsNullOrWhiteSpace(Model.EditedDate) ? Model.EditedDate : string.Empty;
}

@section Styles {
    <link rel="stylesheet" href="~/css/StudentDb/StudentClass.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminDb/AdminClass.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminDb/AdminAssessment.theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminDb/AdminClass.theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminDb/AdminMaterial.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Shared/PublicComments.css" asp-append-version="true" />
    <style>
        .slsp-confirm-backdrop, .slsp-confirm-modal { z-index: 13015; }
        .make-changes-wrap {
            z-index: 12050;
        }
    </style>
}

<main class="student-class-shell admin-class-page admin-material-page" id="adminMaterialPage" data-class-code="@Model.ClassCode" data-dashboard-url="@Url.Content("~/professordb/ProfessorDb")">
    <section class="class-container admin-material-view-container">
        <div class="admin-class-topbar admin-class-topbar--breadcrumb-only">
            <nav class="admin-class-topbar-right class-breadcrumb aae-breadcrumb slsp-crumb-tabs" aria-label="Breadcrumb">
                <a class="slsp-crumb-tab" href="@Url.Content("~/professordb/ProfessorDb")" title="Dashboard">
                    <i class="fa-solid fa-table-cells-large" aria-hidden="true"></i>
                    <span>Dashboard</span>
                </a>
                <span class="slsp-crumb-divider" aria-hidden="true"></span>
                <a class="slsp-crumb-tab" href="@Url.Action("Index", "AdminClass", new { id = Model.ClassCode })" title="@Model.SubjectName">
                    <i class="fa-solid fa-book" aria-hidden="true"></i>
                    <span>@Model.SubjectCode</span>
                </a>
                <span class="slsp-crumb-divider" aria-hidden="true"></span>
                <span class="slsp-crumb-tab is-active" aria-current="page" title="@Model.MaterialName">
                    <i class="fa-regular fa-file-lines" aria-hidden="true"></i>
                    <span>@Model.MaterialName</span>
                </span>
            </nav>
        </div>

        <section class="class-info aae-profile-card">
            <div class="aae-profile">
                <div class="aae-profile-avatar" aria-hidden="true">@Model.InstructorInitials</div>
                <div class="aae-profile-text">
                    <div class="aae-profile-name">@Model.InstructorName</div>
                    <div class="aae-profile-secondary">
                        @Model.TeacherRole
                        @if (!string.IsNullOrWhiteSpace(Model.TeacherDepartment))
                        {
                            <text> · @Model.TeacherDepartment</text>
                        }
                    </div>
                    <div class="aae-profile-secondary aae-profile-muted">
                        @Model.RoomName
                        @if (!string.IsNullOrWhiteSpace(Model.FloorDisplay))
                        {
                            <text> · @Model.FloorDisplay</text>
                        }
                    </div>
                </div>
            </div>

            <div class="aae-subject-block">
                <h2 class="aae-subject-title">@Model.SubjectName</h2>
                <p class="aae-subject-line"><span class="aae-label">Subject code</span> <span class="aae-value">@Model.SubjectCode</span></p>
                <p class="aae-subject-line"><span class="aae-label">Class code</span> <span class="aae-value">@Model.ClassCode</span></p>
            </div>

            <div class="aae-divider" role="presentation"></div>

            <div class="class-info-middle">
                @if (Model.RecentMaterials != null && Model.RecentMaterials.Count > 0)
                {
                    <div class="recent-uploads">
                        <h3 class="aae-aside-heading"><i class="fa-regular fa-clock"></i> Recent Materials</h3>
                        <ul>
                            @foreach (var u in Model.RecentMaterials)
                            {
                                <li class="recent-upload-row @(string.Equals(u.ContentId, Model.MaterialId, StringComparison.Ordinal) ? "is-current" : "")" data-content-id="@(u.ContentId ?? "")">
                                    @if (!string.IsNullOrWhiteSpace(u.TargetUrl) && u.TargetUrl != "#")
                                    {
                                        <a class="recent-upload-link" href="@u.TargetUrl">
                                            <i class="@u.IconClass" aria-hidden="true"></i>
                                            <span class="recent-title">@u.Title</span>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="recent-upload-static">
                                            <i class="@u.IconClass" aria-hidden="true"></i>
                                            <span class="recent-title">@u.Title</span>
                                        </span>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </section>

        <section class="class-content admin-material-right-column" id="classContent">
            <div class="admin-material-stack">
                <section class="material-container aae-assessment-card" id="materialContainer" data-material-id="@Model.MaterialId">
                    <div class="material-scrollable aae-assessment-body">
                        <header class="aae-card-header">
                            <div class="aae-title-row">
                                <h2 class="material-name aae-assessment-name" id="materialName" contenteditable="false">@Model.MaterialName</h2>
                            </div>
                        </header>

                        <p class="material-description aae-description" id="materialDescription" contenteditable="false">@Model.MaterialDescription</p>

                        <div class="aae-divider soft" role="presentation"></div>

                        <div id="dateInfo" class="aae-meta-row" data-posted="@postedDisplay" data-edited="@editedDisplay">
                            <div class="aae-meta-item">
                                <span class="aae-meta-icon" aria-hidden="true"><i class="fa-regular fa-calendar"></i></span>
                                <span class="aae-meta-label">Posted</span>
                                <span class="aae-meta-value">@postedDisplay</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(editedDisplay))
                            {
                                <div class="aae-meta-item">
                                    <span class="aae-meta-icon" aria-hidden="true"><i class="fa-regular fa-pen-to-square"></i></span>
                                    <span class="aae-meta-label">Edited</span>
                                    <span class="aae-meta-value">@editedDisplay</span>
                                </div>
                            }
                        </div>

                        <div class="aae-divider soft" role="presentation"></div>

                        <section class="attachments-section aae-files-section">
                            <h3 class="aae-section-heading"><i class="fa-regular fa-file-lines"></i> Attached files</h3>
                            <div id="attachmentDropzone" class="aae-dropzone @(Model.Attachments.Any() ? "has-files" : "")">
                                <div class="attachments aae-attachments" id="attachmentList">
                                    @if (Model.Attachments.Any())
                                    {
                                        @foreach (var file in Model.Attachments)
                                        {
                                            <div class="attachment-box aae-file-chip" data-file-label="@file">
                                                <a href="#" class="attachment-name" data-filename="@file" data-contentid="@Model.MaterialId" title="Open @file">@file</a>
                                            </div>
                                        }
                                    }
                                </div>
                                @if (!Model.Attachments.Any())
                                {
                                    <div class="aae-empty-files" id="attachmentEmptyState">
                                        <div class="aae-empty-icon" aria-hidden="true"><i class="fa-regular fa-folder-open"></i></div>
                                        <p class="aae-empty-title">No files yet</p>
                                        <p class="aae-empty-hint">Use <strong>Replace file</strong> while editing to add an attachment.</p>
                                    </div>
                                }
                            </div>
                        </section>
                    </div>

                    <div class="edit-controls" id="editControls" hidden>
                        <input type="file" id="replaceFileInput" accept="*/*" hidden />
                        <button type="button" class="btn" id="replaceFileBtn" title="Replace attached file"><i class="fa-solid fa-file-arrow-up"></i> Replace File</button>
                        <button type="button" class="btn save-btn" id="saveEditBtn">Save</button>
                        <button type="button" class="btn cancel-btn" id="cancelEditBtn">Cancel</button>
                    </div>
                </section>

                <section class="public-comment-container" id="adminCommentContainer">
                    <h3 class="public-comment-header">Comments</h3>
                    <form id="adminCommentForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="contentId" value="@Model.MaterialId" />
                        <input type="hidden" name="classCode" value="@Model.ClassCode" />
                    </form>
                    <div class="public-comment-input">
                        <textarea id="adminCommentText" placeholder="Add a class comment..."></textarea>
                        <button type="button" id="postAdminCommentBtn" class="post-comment-btn">Post</button>
                    </div>
                    <div class="public-comment-list" id="adminCommentList"></div>
                </section>
            </div>
        </section>
    </section>
</main>

<!-- In-page file viewer (Admin Material) -->
<div id="amFileViewer" class="sm-file-viewer" style="display:none;">
    <div class="sm-file-dialog">
        <div class="sm-file-header">
            <div id="amFileTitle" class="sm-file-title">File</div>
            <a id="amOpenNewTab" href="#" rel="noopener" class="sm-file-action sm-file-open">Open in new tab</a>
            <a id="amDownload" href="#" download class="sm-file-action sm-file-download">Download</a>
            <button type="button" id="amCloseViewer" class="sm-file-close" aria-label="Close">×</button>
        </div>
        <div id="amViewerBody" class="sm-file-body"></div>
    </div>
</div>

<!-- Open confirmation modal -->
<div id="amOpenConfirmBackdrop" class="slsp-confirm-backdrop" hidden aria-hidden="true"></div>
<div id="amOpenConfirmModal" class="slsp-confirm-modal" role="dialog" aria-modal="true" aria-labelledby="amOpenConfirmTitle" aria-describedby="amOpenConfirmDesc" hidden>
    <div class="slsp-confirm-card">
        <div class="slsp-confirm-header">
            <div class="slsp-confirm-icon" aria-hidden="true"><i class="fa-solid fa-up-right-from-square"></i></div>
            <h2 id="amOpenConfirmTitle" class="slsp-confirm-title">Open file</h2>
            <p id="amOpenConfirmDesc" class="slsp-confirm-desc">Do you want to open this file in a new tab?</p>
        </div>
        <div class="slsp-confirm-actions">
            <button type="button" id="amOpenConfirmCancel" class="slsp-confirm-btn slsp-confirm-cancel">Cancel</button>
            <button type="button" id="amOpenConfirmOk" class="slsp-confirm-btn slsp-confirm-primary">Open</button>
        </div>
    </div>
</div>

<!-- Download confirmation modal -->
<div id="amDownloadConfirmBackdrop" class="slsp-confirm-backdrop" hidden aria-hidden="true"></div>
<div id="amDownloadConfirmModal" class="slsp-confirm-modal" role="dialog" aria-modal="true" aria-labelledby="amDownloadConfirmTitle" aria-describedby="amDownloadConfirmDesc" hidden>
    <div class="slsp-confirm-card">
        <div class="slsp-confirm-header">
            <div class="slsp-confirm-icon" aria-hidden="true"><i class="fa-solid fa-download"></i></div>
            <h2 id="amDownloadConfirmTitle" class="slsp-confirm-title">Download file</h2>
            <p id="amDownloadConfirmDesc" class="slsp-confirm-desc">Do you want to download this file?</p>
        </div>
        <div class="slsp-confirm-actions">
            <button type="button" id="amDownloadConfirmCancel" class="slsp-confirm-btn slsp-confirm-cancel">Cancel</button>
            <button type="button" id="amDownloadConfirmOk" class="slsp-confirm-btn slsp-confirm-primary">Download</button>
        </div>
    </div>
</div>

<div class="make-changes-wrap">
    <div class="make-changes-button" id="makeChangesButton" title="Make Changes">
        <i class="fa-solid fa-pen-to-square"></i>
    </div>

    <div class="admin-actions" id="adminActions" aria-hidden="true">
        <div class="admin-action" data-action="edit">
            <span class="label">Edit</span>
            <button type="button"><i class="fa-solid fa-pen"></i></button>
        </div>
        <div class="admin-action" data-action="delete">
            <span class="label">Delete</span>
            <button type="button"><i class="fa-solid fa-trash"></i></button>
        </div>
    </div>
</div>

<div id="deleteMaterialConfirmBackdrop" class="slsp-confirm-backdrop" hidden aria-hidden="true"></div>
<div id="deleteMaterialConfirmModal" class="slsp-confirm-modal" role="dialog" aria-modal="true" aria-labelledby="deleteMaterialConfirmTitle" hidden>
    <div class="slsp-confirm-card">
        <div class="slsp-confirm-header">
            <div class="slsp-confirm-icon" aria-hidden="true"><i class="fa-solid fa-trash"></i></div>
            <h2 id="deleteMaterialConfirmTitle" class="slsp-confirm-title">Delete material</h2>
            <p class="slsp-confirm-desc">This action cannot be undone.</p>
        </div>
        <div class="slsp-confirm-actions">
            <button type="button" class="slsp-confirm-btn slsp-confirm-cancel" id="cancelDelete">Cancel</button>
            <button type="button" class="slsp-confirm-btn slsp-confirm-primary" id="confirmDelete">Delete</button>
        </div>
    </div>
</div>

<div id="saveMaterialConfirmBackdrop" class="slsp-confirm-backdrop" hidden aria-hidden="true"></div>
<div id="saveMaterialConfirmModal" class="slsp-confirm-modal" role="dialog" aria-modal="true" aria-labelledby="saveMaterialConfirmTitle" hidden>
    <div class="slsp-confirm-card">
        <div class="slsp-confirm-header">
            <div class="slsp-confirm-icon" aria-hidden="true"><i class="fa-solid fa-floppy-disk"></i></div>
            <h2 id="saveMaterialConfirmTitle" class="slsp-confirm-title">Save changes</h2>
            <p class="slsp-confirm-desc">Update this material for the class?</p>
        </div>
        <div class="slsp-confirm-actions">
            <button type="button" class="slsp-confirm-btn slsp-confirm-cancel" id="saveMaterialConfirmCancel">Cancel</button>
            <button type="button" class="slsp-confirm-btn slsp-confirm-primary" id="saveMaterialConfirmOk">Save</button>
        </div>
    </div>
</div>

<div id="toast" class="toast" aria-live="polite" role="status"></div>

@section Scripts {
    <script src="~/js/AdminDb/AdminMaterial.js" asp-append-version="true"></script>
}
