@model StudentPortal.Models.AdminDb.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    var toastMessage = TempData["ToastMessage"] as string;
    Layout = null;
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/AdminDb/AdminDb.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Shared/BottomBar.css" asp-append-version="true" />
    <style>
        /* ensure modal covers bottom-bar (if bottom bar lives outside page wrapper) */
        .modal-backdrop {
            position: fixed;
            inset: 0;
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 12000;
        }

        .class-code {
            color: white;
        }

        .modal-backdrop.show {
            display: flex;
        }
    </style>
</head>
<body>
    <div class="page">
        <main class="classes-container" id="classContainer">
            @foreach (var cls in Model.Classes)
            {
                <article class="class-card">
                    <div class="class-left has-bg"
                         style="background-image:url('https://images.unsplash.com/photo-1523240795612-9a054b0db644?q=80&w=1400&auto=format&fit=crop'); background-size: cover; background-position: center; background-repeat: no-repeat;"
                         onclick="location.href='@Url.Action("Index", "AdminClass", new { id = cls.ClassCode })'">
                        <div class="class-name">@cls.SubjectName</div>
                        <div class="class-section">
                            @if (!string.IsNullOrWhiteSpace(cls.SectionLabel))
                            {
                                @($"Section: {cls.SectionLabel}")
                            }
                            else
                            {
                                @($"Code: {cls.SubjectCode}")
                            }
                        </div>
                        <div class="class-code">Class Code: @cls.ClassCode</div>
                    </div>
                    <div class="class-right">
                        <div class="instructor-profile-image">@cls.CreatorInitials</div>
                        <div>
                            <div class="instructor-profile-name">@cls.CreatorName</div>
                            <div class="instructor-role">@cls.CreatorRole</div>
                        </div>
                        <button class="delete-class-btn" data-class-id="@cls.Id" data-class-code="@cls.ClassCode" title="Delete"><i class="fa-solid fa-trash"></i></button>
                    </div>
                </article>
            }


            <!-- Create class button -->
            <button class="create-class-button" id="createBtn" type="button" title="Create class" aria-haspopup="dialog" aria-controls="createModal">
                <i class="fa-solid fa-pen-to-square"></i>
            </button>
        </main>

        <!-- Modal for creating class -->
        <div class="modal-backdrop" id="modalBackdrop" role="presentation" aria-hidden="true">
            <div class="modal" id="createModal" role="dialog" aria-modal="true" aria-labelledby="createTitle">
                <h3 id="createTitle">Create a Class</h3>

                <form id="createForm" method="post" asp-controller="AdminDb" asp-action="CreateClass">
                    @Html.AntiForgeryToken()
                    <div class="custom-select" id="profSubjectSelect" data-value="">
                        <div class="selected">Select Professor Subject</div>
                        <div class="options"></div>
                    </div>
                    <input type="hidden" id="profSubjectValue" />
                    <input type="hidden" id="scheduleId" name="scheduleId" />

                    <div class="custom-select" id="courseSelect" data-value="">
                        <div class="selected">Select Course</div>
                        <div class="options">
                            <div data-value="BSIT">BSIT</div>
                            <div data-value="BSENT">BSENT</div>
                        </div>
                    </div>
                    <input type="hidden" name="course" id="courseValue" />

                    <div class="custom-select" id="yearSelect" data-value="">
                        <div class="selected">Select Year</div>
                        <div class="options">
                            <div data-value="1st">1st</div>
                            <div data-value="2nd">2nd</div>
                            <div data-value="3rd">3rd</div>
                            <div data-value="4th">4th</div>
                        </div>
                    </div>
                    <input type="hidden" name="year" id="yearValue" />

                    <div class="custom-select" id="semesterSelect" data-value="">
                        <div class="selected">Select Semester</div>
                        <div class="options">
                            <div data-value="1st">1st</div>
                            <div data-value="2nd">2nd</div>
                        </div>
                    </div>
                    <input type="hidden" name="semester" id="semesterValue" />

                    <input type="text" id="section" name="section" placeholder="Enter section (e.g., BSIT-2025-2025-0017)" />
                    <input type="email" id="profEmail" name="profEmail" placeholder="Professor email (optional)" />
                    <input type="text" id="professorId" name="professorId" placeholder="Professor ID (ESys)" />
                    <input type="text" id="subjectName" name="subjectName" placeholder="Enter subject name" />
                    <input type="text" id="subjectCode" name="subjectCode" placeholder="Enter subject code" />

                    <button id="createClass" type="submit">CREATE CLASS</button>
                </form>
            </div>
        </div>
        <div class="modal-backdrop" id="deleteClassBackdrop" role="presentation" aria-hidden="true">
            <div class="modal" id="deleteClassModal" role="dialog" aria-modal="true" aria-labelledby="deleteClassTitle">
                <h3 id="deleteClassTitle">Delete Class</h3>
                <p id="deleteClassText"></p>
                <div class="modal-actions">
                    <button id="cancelDeleteClass" type="button">Cancel</button>
                    <button id="confirmDeleteClass" type="button">Delete</button>
                </div>
            </div>
        </div>
        <!-- Toast Notification -->
        <div id="toast" class="toast">@toastMessage</div>

        <script src="~/js/AdminDb/AdminDb.js" asp-append-version="true"></script>
        @{
            ViewBag.CurrentPage = "home";
        }
        @await Html.PartialAsync("_AdminBottomBar")

    </div>
</body>
</html>
